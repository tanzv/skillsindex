{
  "defaults": {
    "frontend_port": "3400",
    "backend_port": "38180",
    "frontend_base_url": "http://127.0.0.1:3400",
    "backend_base_url": "http://127.0.0.1:38180"
  },
  "profiles": {
    "skillsindex-backend": {
      "name": "skillsindex-backend",
      "runtime": "go",
      "entry": "./cmd/api",
      "cwd": "backend",
      "args": [],
      "managed": true,
      "mode": "run",
      "log_retention": "temporary",
      "env": {
        "APP_PORT": "${backend_port}",
        "CORS_ALLOWED_ORIGINS": "${frontend_base_url}",
        "DINGTALK_REDIRECT_URL": "${backend_base_url}/auth/dingtalk/callback"
      },
      "prelaunch_task": null,
      "poststop_task": null
    },
    "skillsindex-frontend": {
      "name": "skillsindex-frontend",
      "runtime": "node",
      "entry": "node_modules/next/dist/bin/next",
      "cwd": "frontend-next",
      "args": [
        "start",
        "--hostname",
        "127.0.0.1",
        "--port",
        "${frontend_port}"
      ],
      "managed": true,
      "mode": "run",
      "log_retention": "temporary",
      "env": {
        "NEXT_PUBLIC_API_BASE_URL": "${backend_base_url}",
        "SKILLSINDEX_SERVER_API_BASE_URL": "${backend_base_url}"
      },
      "prelaunch_task": "npm run build",
      "poststop_task": null
    }
  }
}
