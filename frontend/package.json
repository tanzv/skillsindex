{
  "name": "skillsindex-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:visual": "node ./scripts/visual-regression/run.mjs && VISUAL_SCENARIO=workspace-activity node ./scripts/visual-regression/run.mjs",
    "test:visual:workspace": "VISUAL_SCENARIO=workspace-activity node ./scripts/visual-regression/run.mjs",
    "test:visual:login": "VISUAL_SCENARIO=login node ./scripts/visual-regression/run.mjs",
    "test:visual:admin": "VISUAL_SCENARIO=admin-overview node ./scripts/visual-regression/run.mjs",
    "test:visual:update-baseline": "node ./scripts/visual-regression/update-baseline.mjs",
    "test:visual:update-baseline:admin": "VISUAL_SCENARIO=admin-overview node ./scripts/visual-regression/update-baseline.mjs",
    "test:visual:update-baseline:workspace": "VISUAL_SCENARIO=workspace-activity node ./scripts/visual-regression/update-baseline.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:visual:update-baseline:login": "VISUAL_SCENARIO=login node ./scripts/visual-regression/update-baseline.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "antd": "^6.3.1",
    "i18next": "^25.8.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.0.18"
  }
}
