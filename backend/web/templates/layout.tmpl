                    <tr>
                        {{if .AdminShowAPIKeyOwner}}<th>{{tr .Locale "admin.table_owner"}}</th>{{end}}
                        <th>{{tr .Locale "admin.api_key_prefix"}}</th>
                        <th>{{tr .Locale "admin.api_key_name"}}</th>
                        <th>{{tr .Locale "admin.api_key_created_at"}}</th>
                        <th>{{tr .Locale "admin.api_key_last_used"}}</th>
                        <th>{{tr .Locale "admin.api_key_expires_at"}}</th>
                        <th>{{tr .Locale "admin.api_key_scopes"}}</th>
                        <th>{{tr .Locale "admin.api_key_status"}}</th>
                        <th>{{tr .Locale "admin.table_actions"}}</th>
