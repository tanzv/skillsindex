            <form method="post" action="/account/profile" class="stack-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <label>Display Name<input type="text" name="display_name" maxlength="64" value="{{if .CurrentUser}}{{.CurrentUser.DisplayName}}{{end}}"></label>
                <label>Avatar URL<input type="url" name="avatar_url" maxlength="512" value="{{if .CurrentUser}}{{.CurrentUser.AvatarURL}}{{end}}"></label>
                <label>Bio<textarea name="bio" rows="4" maxlength="500">{{if .CurrentUser}}{{.CurrentUser.Bio}}{{end}}</textarea></label>
                <button type="submit" class="primary-btn">Save Profile</button>
            </form>
        </article>
        {{end}}
    </section>
    {{end}}

