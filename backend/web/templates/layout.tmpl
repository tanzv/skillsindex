                            {{else if eq $keyStatus "expired"}}
                            <span class="muted">{{tr $.Locale "admin.api_key_status_expired"}}</span>
                            {{else}}
                            <span>{{tr $.Locale "admin.api_key_status_active"}}</span>
                            {{end}}
