    {{if eq $adminSection "integrations"}}
    <section class="panel admin-integration-shell" id="admin-integrations">
        <div class="admin-integration-header">
            <div>
                <p class="admin-integration-kicker">Integration Hub</p>
                <h2>{{tr .Locale "dingtalk.title"}}</h2>
                <p class="muted">Unify enterprise auth providers, connector inventory, and webhook delivery signals in one operational surface.</p>
            </div>
            <div class="row-actions">
                <a class="ghost-btn" href="/admin/integrations/list">Connector list</a>
                <a class="ghost-btn" href="/admin/integrations/new">Create connector</a>
                <a class="ghost-btn" href="/admin/integrations/webhooks/logs">Webhook logs</a>
            </div>
        </div>

        <div class="admin-integration-kpi-grid">
            <article class="admin-integration-kpi">
                <span>Total connectors</span>
                <strong>{{len .AdminConnectors}}</strong>
            </article>
            <article class="admin-integration-kpi">
                <span>DingTalk config</span>
                <strong>{{if .DingTalkEnabled}}Ready{{else}}Missing{{end}}</strong>
            </article>
            <article class="admin-integration-kpi">
                <span>DingTalk grant</span>
                <strong>{{if .DingTalkGrant}}Authorized{{else}}Not authorized{{end}}</strong>
            </article>
            <article class="admin-integration-kpi">
                <span>Webhook records in view</span>
                <strong>{{len .AdminWebhookLogs}}</strong>
            </article>
        </div>

        {{if eq .AdminIntegrationsMode "list"}}
        <article class="admin-integration-panel">
            <div class="section-head">
                <h3>Connector inventory</h3>
                <p class="muted">Runtime endpoints, ownership metadata, and state at a glance.</p>
            </div>
            {{if .AdminConnectors}}
            <div class="admin-connector-grid">
                {{range .AdminConnectors}}
                <article class="admin-connector-card">
                    <div class="admin-connector-card-head">
                        <h4>{{.Name}}</h4>
                        <span class="admin-connector-state {{if .Enabled}}is-enabled{{else}}is-disabled{{end}}">{{if .Enabled}}Enabled{{else}}Disabled{{end}}</span>
                    </div>
                    <p class="muted">Provider: {{toUpper .Provider}}</p>
                    <p class="muted">Base URL: {{if .BaseURL}}<code>{{.BaseURL}}</code>{{else}}-{{end}}</p>
                    <p class="muted">Creator: {{if .Creator.Username}}{{.Creator.Username}}{{else}}system{{end}}</p>
                    <p class="muted">Created: {{formatDateTime .CreatedAt}}</p>
                    <p>{{if .Description}}{{.Description}}{{else}}No description provided.{{end}}</p>
                    <div class="row-actions">
                        <a class="ghost-btn" href="/admin/integrations">Open overview</a>
                        <a class="ghost-btn" href="/admin/integrations/webhooks/logs">Webhook logs</a>
                    </div>
                </article>
                {{end}}
            </div>
            {{else}}
            <p class="empty">No connectors configured.</p>
            {{end}}
        </article>
        {{else if eq .AdminIntegrationsMode "new"}}
        <div class="admin-integration-form-grid">
            <article class="admin-integration-panel">
                <h3>Create connector</h3>
                <p class="muted">Define transport profile, endpoint base URL, and runtime config JSON.</p>
                <form method="post" action="/admin/integrations/create?section=integrations" class="stack-form admin-form-grid">
                    <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                    <label>Name<input type="text" name="name" maxlength="128" required></label>
                    <label>Provider
                        <select name="provider">
                            <option value="dingtalk">dingtalk</option>
                            <option value="webhook">webhook</option>
                            <option value="custom">custom</option>
                        </select>
                    </label>
                    <label class="admin-form-span-2">Base URL<input type="url" name="base_url" maxlength="512"></label>
                    <label class="admin-form-span-2">Description<textarea name="description" rows="2" maxlength="1024"></textarea></label>
                    <label class="admin-form-span-2">Config JSON<textarea name="config_json" rows="6" placeholder='{"key":"value"}'></textarea></label>
                    <label><input type="checkbox" name="enabled" value="true" checked> Enabled</label>
                    <button type="submit" class="primary-btn">Create connector</button>
                </form>
            </article>
            <article class="admin-integration-panel admin-integration-side-notes">
                <h3>Connector design notes</h3>
                <ul class="plain-list">
                    <li>Prefer provider-specific connector names to avoid route ambiguity.</li>
                    <li>Keep `base_url` environment-specific and stable for webhook signatures.</li>
                    <li>Store only non-secret config in `config_json`; keep tokens in secure vaults.</li>
                </ul>
                <div class="row-actions">
                    {{if .DingTalkEnabled}}
                    <a class="ghost-btn" href="/auth/dingtalk/start">{{tr .Locale "dingtalk.action_authorize"}}</a>
                    {{else}}
                    <span class="muted">{{tr .Locale "dingtalk.not_configured"}}</span>
                    {{end}}
                </div>
            </article>
        </div>
        {{else if eq .AdminIntegrationsMode "webhooks"}}
        <article class="admin-integration-panel">
            <div class="section-head">
                <h3>Webhook delivery logs</h3>
                <p class="muted">Latest delivery traces with endpoint outcomes and diagnostics.</p>
            </div>
            <div class="table-wrap admin-webhook-table">
                <table>
                    <thead>
                        <tr>
                            <th>Delivered</th>
                            <th>Connector</th>
                            <th>Event</th>
                            <th>Endpoint</th>
                            <th>Status</th>
                            <th>Outcome</th>
                            <th>Request ID</th>
                            <th>Error</th>
                        </tr>
                    </thead>
                    <tbody>
                    {{if .AdminWebhookLogs}}
                        {{range .AdminWebhookLogs}}
                        <tr>
                            <td>{{formatDateTime .DeliveredAt}}</td>
                            <td>{{.Connector.Name}}</td>
                            <td>{{.EventType}}</td>
                            <td><code>{{.Endpoint}}</code></td>
                            <td>{{.StatusCode}}</td>
                            <td><span class="admin-webhook-outcome outcome-{{.Outcome}}">{{toUpper .Outcome}}</span></td>
                            <td>{{if .RequestID}}{{.RequestID}}{{else}}-{{end}}</td>
                            <td>{{if .ErrorMessage}}{{.ErrorMessage}}{{else}}-{{end}}</td>
                        </tr>
                        {{end}}
                    {{else}}
                        <tr><td colspan="8">No webhook delivery logs.</td></tr>
                    {{end}}
                    </tbody>
                </table>
            </div>
        </article>
        {{else}}
        <div class="admin-integration-overview-grid">
            <article class="admin-integration-panel">
                <h3>DingTalk authorization state</h3>
                {{if .DingTalkEnabled}}
                    {{if .DingTalkGrant}}
                        <p class="muted">{{tr .Locale "dingtalk.bound_external_id"}}: <code>{{.DingTalkGrant.ExternalUserID}}</code></p>
                        <p class="muted">{{tr .Locale "dingtalk.expires_at"}}: {{formatDateTime .DingTalkGrant.ExpiresAt}}</p>
                        <div class="row-actions">
                            <a class="ghost-btn" href="/auth/dingtalk/start">{{tr .Locale "dingtalk.action_reauthorize"}}</a>
                            <a class="ghost-btn" href="/api/v1/dingtalk/me" target="_blank">{{tr .Locale "dingtalk.action_check_profile"}}</a>
                            <form method="post" action="/auth/dingtalk/revoke?section=integrations" class="inline-form">
                                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                                <button type="submit" class="danger-btn">{{tr .Locale "dingtalk.action_revoke"}}</button>
                            </form>
                        </div>
                    {{else}}
                        <p class="muted">{{tr .Locale "dingtalk.not_authorized"}}</p>
                        <a class="primary-btn" href="/auth/dingtalk/start">{{tr .Locale "dingtalk.action_authorize"}}</a>
                    {{end}}
                {{else}}
                    <p class="muted">{{tr .Locale "dingtalk.not_configured"}}</p>
                {{end}}
            </article>
            <article class="admin-integration-panel">
                <h3>Connector summary</h3>
                {{if .AdminConnectors}}
                <div class="admin-connector-summary-list">
                    {{range .AdminConnectors}}
                    <article class="admin-connector-summary-item">
                        <div>
                            <strong>{{.Name}}</strong>
                            <p class="muted">{{toUpper .Provider}} · {{if .Enabled}}Enabled{{else}}Disabled{{end}}</p>
                        </div>
                        <a class="ghost-btn" href="/admin/integrations/list">Open</a>
                    </article>
                    {{end}}
                </div>
                {{else}}
                <p class="empty">No connectors configured yet.</p>
                {{end}}
            </article>
        </div>
        {{end}}
    </section>
    {{end}}

    {{if eq $adminSection "moderation"}}
    <section class="panel" id="admin-moderation">
        <h2>{{tr .Locale "admin.moderation_title"}}</h2>
        <p class="muted">{{tr .Locale "admin.moderation_summary"}}</p>

