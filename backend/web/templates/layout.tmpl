                                    <input type="hidden" name="api_key_owner" value="{{$.AdminAPIKeyOwner}}">
                                    <input type="hidden" name="api_key_status" value="{{$.AdminAPIKeyStatus}}">
                                    <button type="submit" class="danger-btn">{{tr $.Locale "admin.api_key_revoke"}}</button>
                                </form>
                            </div>
                            {{else}}
                            <span class="muted">-</span>
                            {{end}}
                        </td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td {{if .AdminShowAPIKeyOwner}}colspan="9"{{else}}colspan="8"{{end}}>{{tr .Locale "admin.api_key_empty"}}</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
    </section>
    {{end}}

