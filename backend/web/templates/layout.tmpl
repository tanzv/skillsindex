{{define "layout"}}
<!doctype html>
<html lang="{{if eq .Locale "zh"}}zh-CN{{else}}en{{end}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{tr .Locale .Title}} | SkillsIndex</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Manrope:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/app.css">
    {{if eq .Page "swagger"}}
    <link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5/swagger-ui.css">
    {{end}}
</head>
<body class="{{bodyClass .Page}}">
<div class="bg-grid"></div>
{{if isAdminPage .Page}}
<header class="admin-header">
    <div class="container admin-topbar">
        <a class="admin-brand" href="/admin">
            <span class="brand-badge">$</span>
            <span>SkillsIndex Admin</span>
        </a>
        <div class="admin-topbar-context">
            <strong>{{tr .Locale "admin.title"}}</strong>
            {{if .CurrentUser}}
            <span>{{.CurrentUser.Username}} · {{tr .Locale (roleKey .CurrentUser.Role)}}</span>
            {{end}}
        </div>
        <div class="admin-topbar-actions">
            <a class="ghost-btn" href="/">{{tr .Locale "admin.back_marketplace"}}</a>
            {{if .CurrentUser}}
            <form method="post" action="/logout" class="inline-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <button type="submit" class="ghost-btn">{{tr .Locale "nav.sign_out"}}</button>
            </form>
            {{else}}
            <a href="/login">{{tr .Locale "nav.sign_in"}}</a>
            {{end}}
            <div class="locale-switch">
                <a href="{{.LocaleSwitchEN}}" class="{{if eq .Locale "en"}}is-active{{end}}">EN</a>
                <a href="{{.LocaleSwitchZH}}" class="{{if eq .Locale "zh"}}is-active{{end}}">ZH</a>
            </div>
        </div>
    </div>
</header>
{{else if isAuthShellPage .Page}}
<header class="auth-header">
    <div class="container auth-topbar">
        <a class="brand auth-topbar-brand" href="/">
            <span class="brand-badge">$</span>
            <span>SkillsIndex</span>
        </a>
        <p class="auth-topbar-nav">Product  Security  Pricing</p>
        <div class="auth-topbar-locale">
            <a href="{{.LocaleSwitchEN}}" class="{{if eq .Locale "en"}}is-active{{end}}">EN</a>
            <a href="{{.LocaleSwitchZH}}" class="{{if eq .Locale "zh"}}is-active{{end}}">ZH</a>
        </div>
    </div>
</header>
{{else if eq .Page "home"}}
<header class="home-topbar-shell">
    <div class="container home-topbar">
        <a class="home-topbar-brand" href="/">
            <span class="home-topbar-brand-dot">SI</span>
            <span class="home-topbar-brand-copy">
                <strong>{{tr .Locale "home.brand_title"}}</strong>
                <small>{{tr .Locale "home.brand_subtitle"}}</small>
            </span>
        </a>
        <nav class="home-topbar-nav" aria-label="Marketplace navigation">
            <a href="/" class="is-active"><span class="home-topbar-nav-dot"></span>{{tr .Locale "nav.marketplace"}}</a>
            <a href="/categories"><span class="home-topbar-nav-dot"></span>{{tr .Locale "nav.categories"}}</a>
            <a href="/compare"><span class="home-topbar-nav-dot"></span>{{tr .Locale "nav.compare"}}</a>
            <a href="/docs"><span class="home-topbar-nav-dot"></span>{{tr .Locale "nav.docs"}}</a>
        </nav>
        <div class="home-topbar-actions">
            <span class="home-topbar-status">{{tr .Locale "home.top_status"}} {{.TotalSkills}} {{tr .Locale "home.unit_skills"}}</span>
            {{if .CurrentUser}}
                {{if canAccessDashboard .CurrentUser}}
                <a class="home-topbar-cta" href="/admin">{{tr .Locale "home.top_cta_submit"}}</a>
                {{else}}
                <a class="home-topbar-cta" href="/skills/{{if .FeaturedSkills}}{{(index .FeaturedSkills 0).ID}}{{else}}1{{end}}">{{tr .Locale "home.top_cta_submit"}}</a>
                {{end}}
            {{else}}
            <a class="home-topbar-cta" href="/login">{{tr .Locale "home.top_cta_submit"}}</a>
            {{end}}
        </div>
    </div>
</header>
{{else}}
<header class="site-header">
    <div class="container nav">
        <a class="brand" href="/">
            <span class="brand-badge">$</span>
            <span>SkillsIndex</span>
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
            <div class="nav-main">
                <a href="/" class="{{if or (eq .Page "home") (eq .Page "detail")}}is-active{{end}}">{{tr .Locale "nav.marketplace"}}</a>
                <a href="/categories" class="{{if or (eq .Page "categories") (eq .Page "category")}}is-active{{end}}">{{tr .Locale "nav.categories"}}</a>
                <a href="/timeline" class="{{if eq .Page "timeline"}}is-active{{end}}">{{tr .Locale "nav.timeline"}}</a>
                <a href="/compare" class="{{if eq .Page "compare"}}is-active{{end}}">{{tr .Locale "nav.compare"}}</a>
                <a href="/rollout" class="{{if eq .Page "rollout"}}is-active{{end}}">{{tr .Locale "nav.rollout"}}</a>
                <a href="/workspace" class="{{if eq .Page "workspace"}}is-active{{end}}">{{tr .Locale "nav.workspace"}}</a>
                <a href="/governance" class="{{if eq .Page "governance"}}is-active{{end}}">{{tr .Locale "nav.governance"}}</a>
                <details class="nav-more {{if or (eq .Page "docs") (eq .Page "api_docs") (eq .Page "swagger") (eq .Page "about") (eq .Page "prototype_auth")}}is-active{{end}}">
                    <summary>More</summary>
                    <div class="nav-more-menu">
                        <a href="/docs" class="{{if eq .Page "docs"}}is-active{{end}}">{{tr .Locale "nav.docs"}}</a>
                        <a href="/docs/api" class="{{if or (eq .Page "api_docs") (eq .Page "swagger")}}is-active{{end}}">{{tr .Locale "nav.api"}}</a>
                        <a href="/about" class="{{if eq .Page "about"}}is-active{{end}}">{{tr .Locale "nav.about"}}</a>
                        <a href="/prototype/auth" class="{{if eq .Page "prototype_auth"}}is-active{{end}}">{{tr .Locale "nav.prototype"}}</a>
                    </div>
                </details>
                {{if and .CurrentUser (canAccessDashboard .CurrentUser)}}
                <a href="/admin" class="{{if isAdminPage .Page}}is-active{{end}}">{{tr .Locale "nav.admin"}}</a>
                {{end}}
                {{if .CurrentUser}}
                <a href="/account/profile" class="{{if eq .Page "account"}}is-active{{end}}">Account</a>
                {{end}}
            </div>
            <div class="nav-actions">
                {{if .CurrentUser}}
                    <form method="post" action="/logout" class="inline-form">
                        <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                        <button type="submit" class="ghost-btn">{{tr .Locale "nav.sign_out"}}</button>
                    </form>
                {{else}}
                    <a href="/login" class="{{if eq .Page "login"}}is-active{{end}}">{{tr .Locale "nav.sign_in"}}</a>
                    {{if .AllowRegistration}}<a class="solid-link" href="/register">{{tr .Locale "nav.create_account"}}</a>{{end}}
                {{end}}
                <div class="locale-switch">
                    <a href="{{.LocaleSwitchEN}}" class="{{if eq .Locale "en"}}is-active{{end}}">EN</a>
                    <a href="{{.LocaleSwitchZH}}" class="{{if eq .Locale "zh"}}is-active{{end}}">ZH</a>
                </div>
            </div>
        </nav>
    </div>
</header>
{{end}}

<main class="container main-content {{if isAdminPage .Page}}admin-main-content{{end}}">
    {{if .Message}}<div class="alert success">{{.Message}}</div>{{end}}
    {{if .Error}}<div class="alert danger">{{.Error}}</div>{{end}}

    {{if eq .Page "home"}}
    <section class="home-prototype">
        <section class="home-prototype-hero">
            <div class="home-prototype-hero-main">
                <p class="home-prototype-kicker">{{tr .Locale "home.kicker"}}</p>
                <h1 class="home-prototype-headline">{{tr .Locale "home.headline"}}</h1>
                <p class="home-prototype-summary">{{tr .Locale "home.summary"}}</p>
                <div class="home-prototype-hero-tags">
                    <span>{{tr .Locale "home.prototype.hero_tag_explain"}}</span>
                    <span>{{tr .Locale "home.prototype.hero_tag_filter"}}</span>
                    <span>{{tr .Locale "home.prototype.hero_tag_rollout"}}</span>
                </div>
            </div>
            <aside class="home-prototype-hero-side">
                <div class="home-prototype-metric-grid">
                    <article class="home-prototype-metric is-primary">
                        <h3>{{tr .Locale "home.metric_public_skills"}}</h3>
                        <strong>{{.TotalSkills}}</strong>
                    </article>
                    <article class="home-prototype-metric is-accent">
                        <h3>{{tr .Locale "home.prototype.metric_weekly_new"}}</h3>
                        <strong>{{tr .Locale "home.prototype.metric_weekly_new_value"}}</strong>
                    </article>
                    <article class="home-prototype-metric">
                        <h3>{{tr .Locale "home.prototype.metric_success_rate"}}</h3>
                        <strong>{{tr .Locale "home.prototype.metric_success_rate_value"}}</strong>
                    </article>
                    <article class="home-prototype-metric">
                        <h3>{{tr .Locale "home.prototype.metric_install_time"}}</h3>
                        <strong>{{tr .Locale "home.prototype.metric_install_time_value"}}</strong>
                    </article>
                </div>
                <div class="home-prototype-hero-links">
                    <a href="/compare">{{tr .Locale "home.prototype.hero_link_rank"}}</a>
                    <a href="/docs/api">{{tr .Locale "home.prototype.hero_link_report"}}</a>
                    <a href="/governance">{{tr .Locale "home.prototype.hero_link_governance"}}</a>
                </div>
            </aside>
        </section>

        <nav class="home-prototype-flow" aria-label="Marketplace workflow">
            <a href="#home-search-panel">1. Search Scope</a>
            <a href="#home-results-panel">2. Review Matches</a>
            <a href="#home-actions-panel">3. Next Actions</a>
        </nav>

        <section id="home-search-panel" class="home-prototype-search">
            <div class="home-prototype-search-head">
                <div class="home-prototype-search-title">
                    <span class="home-prototype-search-dot"></span>
                    <h2>{{tr .Locale "home.prototype.search_title"}}</h2>
                </div>
                <div class="home-prototype-search-chips">
                    <span>{{tr .Locale "home.prototype.search_chip_keyword"}}</span>
                    <span>{{tr .Locale "home.prototype.search_chip_filter"}}</span>
                    <span>Advanced</span>
                </div>
            </div>
            <form id="home-search-form" method="get" action="/" class="home-prototype-search-form">
                <div class="home-prototype-search-input-row">
                    <label class="home-prototype-input-field is-wide">
                        <span>{{tr .Locale "home.label_keyword"}}</span>
                        <input type="text" name="q" value="{{.Query}}" placeholder="{{tr .Locale "home.placeholder_keyword"}}">
                    </label>
                    <button type="submit" class="home-prototype-search-submit">{{tr .Locale "home.action_search"}}</button>
                </div>
                <div class="home-prototype-search-filter-row is-primary">
                    <label>{{tr .Locale "home.label_mode"}}
                        <select name="mode">
                            <option value="keyword" {{if eq .SearchMode "keyword"}}selected{{end}}>{{tr .Locale "home.mode_keyword"}}</option>
                            <option value="ai" {{if eq .SearchMode "ai"}}selected{{end}}>{{tr .Locale "home.mode_ai"}}</option>
                        </select>
                    </label>
                    <label>{{tr .Locale "home.label_sort"}}
                        <select name="sort">
                            <option value="recent" {{if eq .SortBy "recent"}}selected{{end}}>{{tr .Locale "home.sort_recent"}}</option>
                            <option value="stars" {{if eq .SortBy "stars"}}selected{{end}}>{{tr .Locale "home.sort_stars"}}</option>
                            <option value="quality" {{if eq .SortBy "quality"}}selected{{end}}>{{tr .Locale "home.sort_quality"}}</option>
                        </select>
                    </label>
                    <label>{{tr .Locale "home.label_category"}}
                        <select name="category">
                            <option value="">{{tr .Locale "home.option_all_categories"}}</option>
                            {{range .CatalogCategories}}
                            <option value="{{.Slug}}" {{if eq $.CategoryFilter .Slug}}selected{{end}}>{{.Name}}</option>
                            {{end}}
                        </select>
                    </label>
                </div>
                <details class="home-prototype-search-advanced" {{if or .TagFilter .SubcategoryFilter}}open{{end}}>
                    <summary>Advanced filters{{if or .TagFilter .SubcategoryFilter}} · Active{{end}}</summary>
                    <div class="home-prototype-search-filter-row is-advanced">
                        <label>{{tr .Locale "home.label_tags"}}
                            <input type="text" name="tags" value="{{.TagFilter}}" placeholder="{{tr .Locale "home.placeholder_tags"}}">
                        </label>
                        <label>{{tr .Locale "home.label_subcategory"}}
                            <select name="subcategory">
                                <option value="">{{tr .Locale "home.option_all_subcategories"}}</option>
                                {{range .CatalogCategories}}
                                <optgroup label="{{.Name}}">
                                    {{range .Subcategories}}
                                    <option value="{{.Slug}}" {{if eq $.SubcategoryFilter .Slug}}selected{{end}}>{{.Name}}</option>
                                    {{end}}
                                </optgroup>
                                {{end}}
                            </select>
                        </label>
                    </div>
                </details>
            </form>
        </section>

        <section class="home-prototype-body">
            <aside class="home-prototype-filters">
                <h2>{{tr .Locale "home.prototype.filters_title"}}</h2>
                <div class="home-prototype-filter-row">
                    <span>{{tr .Locale "home.label_mode"}}</span>
                    <strong>{{if eq .SearchMode "ai"}}{{tr .Locale "home.mode_ai"}}{{else}}{{tr .Locale "home.mode_keyword"}}{{end}}</strong>
                </div>
                <div class="home-prototype-filter-row">
                    <span>{{tr .Locale "home.label_sort"}}</span>
                    <strong>{{if eq .SortBy "stars"}}{{tr .Locale "home.sort_stars"}}{{else if eq .SortBy "quality"}}{{tr .Locale "home.sort_quality"}}{{else}}{{tr .Locale "home.sort_recent"}}{{end}}</strong>
                </div>
                <div class="home-prototype-filter-row">
                    <span>{{tr .Locale "home.label_category"}}</span>
                    <strong>{{if .CategoryFilter}}{{.CategoryFilter}}{{else}}{{tr .Locale "home.option_all_categories"}}{{end}}</strong>
                </div>
                <div class="home-prototype-filter-row">
                    <span>{{tr .Locale "home.label_subcategory"}}</span>
                    <strong>{{if .SubcategoryFilter}}{{.SubcategoryFilter}}{{else}}{{tr .Locale "home.option_all_subcategories"}}{{end}}</strong>
                </div>
                <div class="home-prototype-filter-row">
                    <span>{{tr .Locale "home.popular"}}</span>
                    <strong>{{len .TopTags}}</strong>
                </div>
                {{if .TopTags}}
                <div class="home-prototype-filter-tags">
                    {{range .TopTags}}
                    <a href="/?tags={{queryEscape .Name}}">#{{.Name}} ({{.Count}})</a>
                    {{end}}
                </div>
                {{else}}
                <p class="home-prototype-filter-empty">{{tr .Locale "home.empty_tags"}}</p>
                {{end}}
                <div class="home-prototype-filter-actions">
                    <button type="submit" form="home-search-form" class="home-prototype-apply-btn">{{tr .Locale "home.prototype.filters_apply"}}</button>
                    <a href="/" class="home-prototype-reset-btn">{{tr .Locale "home.prototype.filters_reset"}}</a>
                </div>
            </aside>

            <section id="home-results-panel" class="home-prototype-results">
                <div class="home-prototype-results-head">
                    <div class="home-prototype-results-title">
                        <h2>{{tr .Locale "home.results_states_title"}}</h2>
                        <span>{{.TotalItems}} {{tr .Locale "home.matching_skills"}}</span>
                    </div>
                    <span class="home-prototype-results-meta">{{tr .Locale "home.prototype.results_meta"}}</span>
                </div>
                <div class="home-prototype-results-list">
                    {{if .Skills}}
                        {{range .Skills}}
                        <article class="home-prototype-skill-card">
                            <div class="home-prototype-skill-top">
                                <div class="home-prototype-skill-name">
                                    <span class="home-prototype-skill-dot"></span>
                                    <a href="/skills/{{.ID}}">{{.Name}}</a>
                                </div>
                                {{if ge .QualityScore 9.0}}
                                <span class="home-prototype-skill-state is-stable">{{tr $.Locale "home.prototype.status_stable"}}</span>
                                {{else if ge .QualityScore 8.0}}
                                <span class="home-prototype-skill-state is-growing">{{tr $.Locale "home.prototype.status_growing"}}</span>
                                {{else}}
                                <span class="home-prototype-skill-state is-risk">{{tr $.Locale "home.prototype.status_risk"}}</span>
                                {{end}}
                            </div>
                            <div class="home-prototype-skill-tags">
                                <span>{{.SourceType}}</span>
                                <span>{{.CategorySlug}}</span>
                                <span>{{.SubcategorySlug}}</span>
                                {{range .Tags}}
                                <span>{{.Name}}</span>
                                {{end}}
                            </div>
                            <div class="home-prototype-skill-foot">
                                <span>★ {{.StarCount}} · Q {{printf "%.1f" .QualityScore}} · {{formatTime .UpdatedAt}}</span>
                                <div class="home-prototype-skill-actions">
                                    <a href="/compare">{{tr $.Locale "home.prototype.action_compare"}}</a>
                                    <a href="/skills/{{.ID}}">{{tr $.Locale "home.quick_action_detail"}}</a>
                                </div>
                            </div>
                        </article>
                        {{end}}
                    {{else}}
                    <p class="home-prototype-empty">{{tr .Locale "home.empty_results"}}</p>
                    {{end}}
                </div>
                <div class="home-prototype-results-foot">
                    <div class="home-prototype-pagination">
                        {{if .PrevPageURL}}
                        <a href="{{.PrevPageURL}}">{{tr .Locale "home.pagination_prev"}}</a>
                        {{else}}
                        <span>{{tr .Locale "home.pagination_prev"}}</span>
                        {{end}}
                        <span>{{tr .Locale "home.pagination_page"}} {{.PageNumber}} / {{totalPages .TotalItems .PageSize}}</span>
                        {{if .NextPageURL}}
                        <a href="{{.NextPageURL}}">{{tr .Locale "home.pagination_next"}}</a>
                        {{else}}
                        <span>{{tr .Locale "home.pagination_next"}}</span>
                        {{end}}
                    </div>
                    <div id="home-actions-panel" class="home-prototype-result-actions">
                        <a href="/docs/api">{{tr .Locale "home.prototype.footer_export"}}</a>
                        <a href="/docs/api">{{tr .Locale "home.prototype.footer_copy"}}</a>
                        {{if .CurrentUser}}
                            {{if canAccessDashboard .CurrentUser}}
                            <a class="is-primary" href="/admin">{{tr .Locale "home.prototype.footer_release"}}</a>
                            {{else}}
                            <a class="is-primary" href="/skills/{{if .FeaturedSkills}}{{(index .FeaturedSkills 0).ID}}{{else}}1{{end}}">{{tr .Locale "home.prototype.footer_release"}}</a>
                            {{end}}
                        {{else}}
                        <a class="is-primary" href="/login">{{tr .Locale "home.prototype.footer_release"}}</a>
                        {{end}}
                    </div>
                </div>
            </section>
        </section>
    </section>
    {{end}}

    {{if eq .Page "categories"}}
    <section class="panel matrix-shell aux-shell categories-shell">
        <div class="matrix-head">
            <h1>Skill Categories</h1>
            <p class="matrix-head-note">Marketplace / Categories / Taxonomy</p>
        </div>
        <div class="category-grid aux-category-grid">
            {{range .Categories}}
            {{$categorySlug := .Slug}}
            <article class="category-card">
                <h3><a href="/categories/{{.Slug}}">{{.Name}}</a></h3>
                <p>{{.Description}}</p>
                <p class="muted">{{.Count}} skills</p>
                <div class="chip-row">
                    {{range .Subcategories}}
                    <a class="chip" href="/categories/{{$categorySlug}}?subcategory={{.Slug}}">{{.Name}} ({{.Count}})</a>
                    {{end}}
                </div>
            </article>
            {{end}}
        </div>
    </section>
    {{end}}

    {{if eq .Page "category"}}
    <section class="panel matrix-shell aux-shell category-detail-shell">
        <div class="matrix-head">
            <h1>{{.SelectedCategory.Name}}</h1>
            <p class="matrix-head-note">Category / Filter / Results</p>
        </div>
        <article class="matrix-card">
        <p class="matrix-text">{{.SelectedCategory.Description}}</p>
        <form method="get" action="/categories/{{.SelectedCategory.Slug}}" class="search-grid compact category-filter-grid">
            <label>Subcategory
                <select name="subcategory">
                    <option value="">All</option>
                    {{range .SelectedCategory.Subcategories}}
                    <option value="{{.Slug}}" {{if eq $.SelectedSubcategory .Slug}}selected{{end}}>{{.Name}}</option>
                    {{end}}
                </select>
            </label>
            <label>Keyword
                <input type="text" name="q" value="{{.Query}}" placeholder="search this category">
            </label>
            <label>Tags
                <input type="text" name="tags" value="{{.TagFilter}}">
            </label>
            <label>Sort
                <select name="sort">
                    <option value="recent" {{if eq .SortBy "recent"}}selected{{end}}>Recent</option>
                    <option value="stars" {{if eq .SortBy "stars"}}selected{{end}}>Stars</option>
                    <option value="quality" {{if eq .SortBy "quality"}}selected{{end}}>Quality</option>
                </select>
            </label>
            <div class="button-cell"><button type="submit" class="primary-btn">Filter</button></div>
        </form>
        </article>

        <div class="card-grid">
            {{if .Skills}}
            {{range .Skills}}
            <article class="skill-card">
                <h3><a href="/skills/{{.ID}}">{{.Name}}</a></h3>
                <p>{{.Description}}</p>
                <div class="meta-row"><span>★ {{.StarCount}}</span><span>Q {{printf "%.1f" .QualityScore}}</span><span>{{formatTime .UpdatedAt}}</span></div>
            </article>
            {{end}}
            {{else}}
            <p class="empty">No category skills found.</p>
            {{end}}
        </div>
    </section>
    {{end}}

    {{if eq .Page "timeline"}}
    <section class="panel matrix-shell aux-shell timeline-shell">
        <div class="matrix-head">
            <h1>Skills Timeline</h1>
            <p class="matrix-head-note">Timeline / Growth / Monitoring</p>
        </div>
        <div class="matrix-grid timeline-matrix-grid">
            <article class="matrix-card">
                <div class="timeline-switch">
                    <a class="ghost-btn {{if eq .TimelineInterval "day"}}is-active{{end}}" href="{{.TimelineDayURL}}">Daily</a>
                    <a class="ghost-btn {{if eq .TimelineInterval "week"}}is-active{{end}}" href="{{.TimelineWeekURL}}">Weekly</a>
                    <a class="ghost-btn {{if eq .TimelineInterval "month"}}is-active{{end}}" href="{{.TimelineMonthURL}}">Monthly</a>
                </div>
                <div class="timeline-chart">
                    <svg viewBox="0 0 780 220" preserveAspectRatio="none">
                        <polyline fill="none" stroke="currentColor" stroke-width="3" points="{{.TimelineSVGPoints}}"></polyline>
                    </svg>
                </div>
            </article>
            <article class="matrix-side-card">
                <h2>Timeline Snapshot</h2>
                <p class="matrix-text">Interval: {{toUpper .TimelineInterval}}</p>
                <p class="matrix-text">Buckets: {{len .TimelinePoints}}</p>
                {{if .TimelinePoints}}
                <p class="matrix-text">Latest cumulative: {{(index .TimelinePoints (minus (len .TimelinePoints) 1)).Cumulative}}</p>
                {{else}}
                <p class="matrix-text">Latest cumulative: 0</p>
                {{end}}
            </article>
        </div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Bucket</th><th>New</th><th>Cumulative</th></tr></thead>
                <tbody>
                {{range .TimelinePoints}}
                <tr><td>{{.Bucket}}</td><td>{{.Count}}</td><td>{{.Cumulative}}</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
    </section>
    {{end}}

    {{if eq .Page "compare"}}
    <section class="panel matrix-shell compare-matrix-shell">
        <div class="matrix-head">
            <h1>{{tr .Locale "compare.title"}}</h1>
            <p class="matrix-head-note">{{tr .Locale "compare.head_note"}}</p>
        </div>
        <div class="matrix-grid">
            <div class="matrix-main-column">
                <article class="matrix-card">
                    <h2>{{tr .Locale "compare.selection_set"}}</h2>
                    {{if .FeaturedSkills}}
                        {{range $index, $skill := .FeaturedSkills}}
                        {{if lt $index 3}}
