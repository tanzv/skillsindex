                <button type="button" class="ghost-btn" id="api-key-refresh-btn">Refresh</button>
            </div>
        </form>
        {{else}}
        <form method="get" action="/admin/apikeys" class="search-grid compact" id="api-key-filter-form">
            <label>{{tr .Locale "admin.api_key_filter_status"}}
                <select id="api-key-status-filter" name="api_key_status">
                    <option value="all" {{if eq .AdminAPIKeyStatus "all"}}selected{{end}}>{{tr .Locale "admin.api_key_status_all"}}</option>
                    <option value="active" {{if eq .AdminAPIKeyStatus "active"}}selected{{end}}>{{tr .Locale "admin.api_key_status_active"}}</option>
                    <option value="revoked" {{if eq .AdminAPIKeyStatus "revoked"}}selected{{end}}>{{tr .Locale "admin.api_key_status_revoked"}}</option>
                    <option value="expired" {{if eq .AdminAPIKeyStatus "expired"}}selected{{end}}>{{tr .Locale "admin.api_key_status_expired"}}</option>
                </select>
