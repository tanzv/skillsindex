                        <th>{{tr .Locale "admin.table_action"}}</th>
                        <th>{{tr .Locale "admin.table_target"}}</th>
                        <th>{{tr .Locale "admin.table_summary"}}</th>
                        <th>{{tr .Locale "admin.table_details"}}</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AuditLogs}}
                {{range .AuditLogs}}
                    <tr>
                        <td>{{formatTime .CreatedAt}}</td>
                        <td>{{.ActorUser.Username}}</td>
                        <td>{{.Action}}</td>
                        <td>{{.TargetType}}#{{.TargetID}}</td>
                        <td>{{.Summary}}</td>
                        <td><code>{{.Details}}</code></td>
                    </tr>
                {{end}}
                {{else}}
                    <tr><td colspan="6">{{tr .Locale "admin.empty_audit_logs"}}</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
    </section>
    {{end}}
        </div>
    </section>
    {{end}}
</main>
{{if eq .Page "swagger"}}
<script src="https://unpkg.com/swagger-ui-dist@5/swagger-ui-bundle.js" crossorigin="anonymous"></script>
<script>
window.addEventListener("DOMContentLoaded", function() {
    window.SwaggerUIBundle({
        url: "/openapi.json",
        dom_id: "#swagger-ui",
        deepLinking: true,
        presets: [window.SwaggerUIBundle.presets.apis],
        layout: "BaseLayout"
    });
});
</script>
{{end}}
{{if isAdminPage .Page}}
<script>
window.addEventListener("DOMContentLoaded", function () {
    var body = document.body;
    if (body) {
        body.classList.add("admin-enhanced");
    }

    var tabs = Array.prototype.slice.call(document.querySelectorAll("[data-source-target]"));
    var panels = Array.prototype.slice.call(document.querySelectorAll("[data-source-panel]"));
    function activateSource(name) {
        tabs.forEach(function (tab) {
            tab.classList.toggle("is-active", tab.getAttribute("data-source-target") === name);
        });
        panels.forEach(function (panel) {
            panel.classList.toggle("is-active", panel.getAttribute("data-source-panel") === name);
        });
    }
    tabs.forEach(function (tab) {
        tab.addEventListener("click", function () {
            activateSource(tab.getAttribute("data-source-target"));
        });
    });

    var keywordInput = document.getElementById("skill-record-filter");
    var sourceSelect = document.getElementById("skill-record-source");
    var visibilitySelect = document.getElementById("skill-record-visibility");
    var rows = Array.prototype.slice.call(document.querySelectorAll("[data-skill-row]"));

    function normalize(value) {
        return (value || "").toLowerCase().trim();
    }

    function applySkillFilters() {
        var keyword = normalize(keywordInput && keywordInput.value);
        var source = normalize(sourceSelect && sourceSelect.value);
        var visibility = normalize(visibilitySelect && visibilitySelect.value);

        rows.forEach(function (row) {
            var haystack = [
                row.getAttribute("data-name"),
                row.getAttribute("data-owner"),
                row.getAttribute("data-category")
            ].join(" ").toLowerCase();
            var rowSource = normalize(row.getAttribute("data-source"));
            var rowVisibility = normalize(row.getAttribute("data-visibility"));

            var keywordMatch = !keyword || haystack.indexOf(keyword) !== -1;
            var sourceMatch = source === "all" || rowSource === source;
            var visibilityMatch = visibility === "all" || rowVisibility === visibility;
            row.style.display = keywordMatch && sourceMatch && visibilityMatch ? "" : "none";
        });
    }

    if (keywordInput) {
        keywordInput.addEventListener("input", applySkillFilters);
    }
    if (sourceSelect) {
        sourceSelect.addEventListener("change", applySkillFilters);
    }
    if (visibilitySelect) {
        visibilitySelect.addEventListener("change", applySkillFilters);
    }

    function initAdminAPIKeys() {
        var container = document.getElementById("admin-apikeys");
        if (!container || typeof window.fetch !== "function") {
            return;
        }

        var tableBody = document.getElementById("api-key-table-body");
        var filterForm = document.getElementById("api-key-filter-form");
        var createForm = document.getElementById("api-key-create-form");
        if (!tableBody || !filterForm || !createForm) {
            return;
        }

        var ownerInput = document.getElementById("api-key-owner-filter");
        var statusInput = document.getElementById("api-key-status-filter");
        var refreshBtn = document.getElementById("api-key-refresh-btn");
        var clientAlert = document.getElementById("api-key-client-alert");
        var clientError = document.getElementById("api-key-client-error");
        var hiddenOwnerInput = createForm.querySelector('input[name="api_key_owner"]');
        var hiddenStatusInput = createForm.querySelector('input[name="api_key_status"]');

        var showOwner = container.getAttribute("data-show-owner") === "true";
        var csrfToken = container.getAttribute("data-csrf-token") || "";
        var apiList = container.getAttribute("data-api-list") || "";
        var apiCreate = container.getAttribute("data-api-create") || "";
        var apiRotateTemplate = container.getAttribute("data-api-rotate-template") || "";
        var apiRevokeTemplate = container.getAttribute("data-api-revoke-template") || "";
        var locale = (container.getAttribute("data-locale") || "en").toLowerCase();
        var tableColspan = showOwner ? 9 : 8;
        var labels = {
            created: container.getAttribute("data-label-created") || "API key created:",
            empty: container.getAttribute("data-label-empty") || "No API keys yet.",
            statusActive: container.getAttribute("data-label-status-active") || "Active",
            statusRevoked: container.getAttribute("data-label-status-revoked") || "Revoked",
            statusExpired: container.getAttribute("data-label-status-expired") || "Expired",
            actionRotate: container.getAttribute("data-label-action-rotate") || "Rotate",
            actionRevoke: container.getAttribute("data-label-action-revoke") || "Revoke",
            confirmRotate: container.getAttribute("data-confirm-rotate") || "Rotate this API key?",
            confirmRevoke: container.getAttribute("data-confirm-revoke") || "Revoke this API key?",
            never: container.getAttribute("data-label-never") || "Never",
            legacyScope: container.getAttribute("data-label-legacy-scope") || "legacy-all"
        };

        function escapeHTML(value) {
            return String(value == null ? "" : value)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/\"/g, "&quot;")
                .replace(/'/g, "&#39;");
        }

        function showAlert(messageHTML) {
            if (!clientAlert) {
                return;
            }
            clientAlert.innerHTML = messageHTML;
            clientAlert.hidden = false;
        }

        function hideAlert() {
            if (!clientAlert) {
                return;
            }
            clientAlert.hidden = true;
            clientAlert.innerHTML = "";
        }

        function showError(message) {
            if (!clientError) {
                return;
            }
            clientError.textContent = message || "Request failed";
            clientError.hidden = false;
        }

        function hideError() {
            if (!clientError) {
                return;
            }
            clientError.hidden = true;
            clientError.textContent = "";
        }

        function normalizeStatus(value) {
            var normalized = String(value || "").trim().toLowerCase();
            if (normalized === "revoked" || normalized === "expired" || normalized === "active") {
                return normalized;
            }
            return "all";
        }

        function splitScopes(raw) {
            var value = String(raw || "");
            return value
                .split(/[,\s;]+/)
                .map(function (item) {
                    return item.trim();
                })
                .filter(function (item) {
                    return item.length > 0;
                });
        }

        function formatDateTime(value) {
            if (!value) {
                return labels.never;
            }
            var date = new Date(value);
            if (isNaN(date.getTime())) {
                return labels.never;
            }
            try {
                var localeTag = locale.indexOf("zh") === 0 ? "zh-CN" : "en-US";
                return date.toLocaleString(localeTag, {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                    hour: "2-digit",
                    minute: "2-digit",
                    second: "2-digit",
                    hour12: false
                });
            } catch (_err) {
                return date.toISOString();
            }
        }

        function statusLabel(status) {
            switch (normalizeStatus(status)) {
            case "revoked":
                return labels.statusRevoked;
            case "expired":
                return labels.statusExpired;
            default:
                return labels.statusActive;
            }
        }

        function actionCell(item) {
            if (normalizeStatus(item.status) === "revoked") {
                return '<span class="muted">-</span>';
            }
            return '' +
                '<div class="row-actions">' +
                '<button type="button" class="ghost-btn" data-api-action="rotate" data-api-key-id="' + escapeHTML(item.id) + '">' + escapeHTML(labels.actionRotate) + '</button>' +
                '<button type="button" class="danger-btn" data-api-action="revoke" data-api-key-id="' + escapeHTML(item.id) + '">' + escapeHTML(labels.actionRevoke) + '</button>' +
                '</div>';
        }

        function renderItems(items) {
            if (!Array.isArray(items) || items.length === 0) {
                tableBody.innerHTML = '<tr><td colspan="' + tableColspan + '">' + escapeHTML(labels.empty) + '</td></tr>';
                return;
            }
            var rowsHTML = items.map(function (item) {
                var scopes = Array.isArray(item.scopes) && item.scopes.length > 0 ? item.scopes.join(",") : labels.legacyScope;
                var row = "";
                row += "<tr>";
                if (showOwner) {
                    row += "<td>" + escapeHTML(item.owner_username || "") + "</td>";
                }
                row += "<td><code>" + escapeHTML(item.prefix || "") + "</code></td>";
                row += "<td>" + escapeHTML(item.name || "") + "</td>";
                row += "<td>" + escapeHTML(formatDateTime(item.created_at)) + "</td>";
                row += "<td>" + escapeHTML(formatDateTime(item.last_used_at)) + "</td>";
                row += "<td>" + escapeHTML(formatDateTime(item.expires_at)) + "</td>";
                row += "<td><code>" + escapeHTML(scopes) + "</code></td>";
                row += "<td>" + escapeHTML(statusLabel(item.status)) + "</td>";
                row += "<td>" + actionCell(item) + "</td>";
                row += "</tr>";
                return row;
            }).join("");
            tableBody.innerHTML = rowsHTML;
        }

        function withFilters() {
            var params = new URLSearchParams();
            var status = normalizeStatus(statusInput && statusInput.value);
            if (status && status !== "all") {
                params.set("status", status);
            }
            if (showOwner && ownerInput) {
                var owner = ownerInput.value.trim();
                if (owner !== "") {
                    params.set("owner", owner);
                }
            }
            params.set("limit", "500");
            return params;
        }

        function applyFiltersFromURL() {
            if (typeof window.URLSearchParams !== "function") {
                return;
            }
            var params = new URLSearchParams(window.location.search || "");
            if (showOwner && ownerInput) {
                var owner = params.get("api_key_owner");
                if (owner !== null) {
                    ownerInput.value = owner;
                }
            }
            if (statusInput) {
                var statusRaw = params.get("api_key_status");
                if (statusRaw !== null) {
                    statusInput.value = normalizeStatus(statusRaw);
                }
            }
        }

        function syncFilterURL(mode) {
            if (typeof window.URL !== "function" || !window.history) {
                return;
            }
            var currentURL = new URL(window.location.href);
            var status = normalizeStatus(statusInput && statusInput.value);
            if (status === "all") {
                currentURL.searchParams.delete("api_key_status");
            } else {
                currentURL.searchParams.set("api_key_status", status);
            }
            if (showOwner && ownerInput) {
                var owner = ownerInput.value.trim();
                if (owner === "") {
                    currentURL.searchParams.delete("api_key_owner");
                } else {
                    currentURL.searchParams.set("api_key_owner", owner);
                }
            } else {
                currentURL.searchParams.delete("api_key_owner");
            }

            var nextURL = currentURL.pathname + currentURL.search + currentURL.hash;
            var currentPath = window.location.pathname + window.location.search + window.location.hash;
            if (nextURL === currentPath) {
                return;
            }

            if (mode === "push" && typeof window.history.pushState === "function") {
                window.history.pushState({adminAPIKeysFilter: true}, "", nextURL);
                return;
            }
            if (typeof window.history.replaceState === "function") {
                window.history.replaceState({adminAPIKeysFilter: true}, "", nextURL);
            }
        }

        function syncFallbackHiddenFields() {
            if (hiddenOwnerInput && ownerInput) {
                hiddenOwnerInput.value = ownerInput.value.trim();
            }
            if (hiddenStatusInput && statusInput) {
                hiddenStatusInput.value = normalizeStatus(statusInput.value);
            }
        }

        async function requestJSON(url, options) {
            var method = options && options.method ? options.method : "GET";
            var payload = options && options.body ? options.body : null;
            var headers = {
                "Accept": "application/json"
            };
            if (csrfToken) {
                headers["X-CSRF-Token"] = csrfToken;
            }
            var requestInit = {
                method: method,
                headers: headers,
                credentials: "same-origin"
            };
            if (payload !== null) {
                headers["Content-Type"] = "application/json";
                requestInit.body = JSON.stringify(payload);
            }

            var response = await fetch(url, requestInit);
            var body = {};
            try {
                body = await response.json();
            } catch (_err) {
                body = {};
            }
            if (!response.ok) {
                var message = body.message || body.error || ("Request failed (" + response.status + ")");
                throw new Error(message);
            }
            return body;
        }

        async function loadAPIKeys(options) {
            if (!apiList) {
                return;
            }
            var opts = options || {};
            if (opts.urlMode === "push" || opts.urlMode === "replace") {
                syncFilterURL(opts.urlMode);
            }
            syncFallbackHiddenFields();
            tableBody.innerHTML = '<tr><td colspan="' + tableColspan + '" class="muted">Loading...</td></tr>';
            try {
                var query = withFilters();
                var endpoint = apiList + (query.toString() ? ("?" + query.toString()) : "");
                var data = await requestJSON(endpoint, {method: "GET"});
                hideError();
                renderItems(data.items || []);
            } catch (err) {
                showError(err && err.message ? err.message : "Failed to load API keys");
            }
        }

        async function createAPIKey(event) {
            event.preventDefault();
            if (!apiCreate) {
                createForm.submit();
                return;
            }
            hideError();
            hideAlert();
            syncFallbackHiddenFields();

            var formData = new FormData(createForm);
            var payload = {
                name: String(formData.get("name") || "").trim(),
                expires_in_days: parseInt(String(formData.get("expires_in_days") || "0"), 10) || 0
            };
            var scopes = splitScopes(formData.get("scopes"));
            if (scopes.length > 0) {
                payload.scopes = scopes;
            }
            if (showOwner && ownerInput) {
                var ownerRaw = ownerInput.value.trim();
                if (ownerRaw !== "") {
                    var ownerID = parseInt(ownerRaw, 10);
                    if (!isNaN(ownerID) && ownerID > 0) {
                        payload.owner_user_id = ownerID;
                    }
                }
            }

            try {
                var created = await requestJSON(apiCreate, {
                    method: "POST",
                    body: payload
                });
                var token = String(created.plaintext_key || "").trim();
                if (token !== "") {
                    showAlert(escapeHTML(labels.created) + " <code>" + escapeHTML(token) + "</code>");
                }
                createForm.reset();
                syncFallbackHiddenFields();
                await loadAPIKeys();
            } catch (err) {
                showError(err && err.message ? err.message : "Failed to create API key");
            }
        }

        async function mutateAPIKey(action, keyID) {
            var key = String(keyID || "").trim();
            if (key === "") {
                return;
            }
            var normalizedAction = action === "rotate" ? "rotate" : "revoke";
            var confirmText = normalizedAction === "rotate" ? labels.confirmRotate : labels.confirmRevoke;
            if (confirmText && !window.confirm(confirmText)) {
                return;
            }
            hideError();
            hideAlert();
            try {
                var endpointTemplate = normalizedAction === "rotate" ? apiRotateTemplate : apiRevokeTemplate;
                var endpoint = endpointTemplate.replace("{keyID}", encodeURIComponent(key));
                var result = await requestJSON(endpoint, {method: "POST", body: {}});
                if (normalizedAction === "rotate") {
                    var token = String(result.plaintext_key || "").trim();
                    if (token !== "") {
                        showAlert(escapeHTML(labels.created) + " <code>" + escapeHTML(token) + "</code>");
                    }
                }
                await loadAPIKeys();
            } catch (err) {
                showError(err && err.message ? err.message : "API key action failed");
            }
        }

        filterForm.addEventListener("submit", function (event) {
            event.preventDefault();
            loadAPIKeys({urlMode: "push"});
        });

        createForm.addEventListener("submit", createAPIKey);

        if (refreshBtn) {
            refreshBtn.addEventListener("click", function () {
                loadAPIKeys({urlMode: "push"});
            });
        }

        tableBody.addEventListener("click", function (event) {
            var target = event.target;
            if (!(target instanceof Element)) {
                return;
            }
            var button = target.closest("button[data-api-action]");
            if (!button) {
                return;
            }
            event.preventDefault();
            mutateAPIKey(button.getAttribute("data-api-action"), button.getAttribute("data-api-key-id"));
        });

        var fallbackForms = Array.prototype.slice.call(document.querySelectorAll("#admin-apikeys .api-key-action-form"));
        fallbackForms.forEach(function (form) {
            form.addEventListener("submit", function (event) {
                event.preventDefault();
                mutateAPIKey(form.getAttribute("data-api-action"), form.getAttribute("data-api-key-id"));
            });
        });

        applyFiltersFromURL();
        syncFallbackHiddenFields();
        window.addEventListener("popstate", function () {
            applyFiltersFromURL();
            syncFallbackHiddenFields();
            loadAPIKeys();
        });

        loadAPIKeys();
    }

    initAdminAPIKeys();
});
</script>
{{end}}
</body>
