                                <form method="post" action="/admin/apikeys/{{.ID}}/revoke?section=apikeys" class="inline-form api-key-action-form" data-api-action="revoke" data-api-key-id="{{.ID}}" onsubmit="return confirm('{{tr $.Locale "admin.confirm_revoke_apikey"}}');">
