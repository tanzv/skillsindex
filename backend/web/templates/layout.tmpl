                        <label>{{tr .Locale "admin.field_tags"}}<input type="text" name="tags" placeholder="{{tr .Locale "admin.placeholder_tags"}}"></label>
                        <label>{{tr .Locale "admin.field_category"}}<select name="category">{{range .CatalogCategories}}<option value="{{.Slug}}">{{.Name}}</option>{{end}}</select></label>
                        <label>{{tr .Locale "admin.field_subcategory"}}<select name="subcategory">{{range .CatalogCategories}}{{range .Subcategories}}<option value="{{.Slug}}">{{.Name}}</option>{{end}}{{end}}</select></label>
                        <label>{{tr .Locale "admin.field_install_command"}}<input type="text" name="install_command" placeholder="{{tr .Locale "admin.placeholder_install"}}"></label>
                        <label>{{tr .Locale "admin.field_quality_score"}}<input type="number" name="quality_score" min="0" max="10" step="0.1" value="8.6"></label>
                        <label>{{tr .Locale "admin.field_visibility"}}<select name="visibility"><option value="private">{{tr .Locale "admin.visibility_private"}}</option><option value="public">{{tr .Locale "admin.visibility_public"}}</option></select></label>
