    {{if eq $adminSection "incidents"}}
    <section class="panel" id="admin-incidents">
        <h2>{{tr .Locale "admin.incidents_title"}}</h2>
        <p class="muted">{{tr .Locale "admin.incidents_summary"}}</p>
        {{if eq .AdminIncidentsMode "response"}}
        {{if .AdminIncident}}
        <div class="scenario-grid">
            <article class="scenario-card">
                <h3>Incident #{{.AdminIncident.ID}} response console</h3>
                <p class="muted">{{.AdminIncident.Title}}</p>
                <p class="muted">Severity: {{toUpper (printf "%s" .AdminIncident.Severity)}} | Status: {{toUpper (printf "%s" .AdminIncident.Status)}}</p>
                <p class="muted">Detected: {{formatDateTime .AdminIncident.DetectedAt}}</p>
                {{if .AdminIncident.ResolvedAt}}<p class="muted">Resolved: {{formatTimePtr .AdminIncident.ResolvedAt}}</p>{{end}}
                <form method="post" action="/admin/incidents/{{.AdminIncident.ID}}/response?section=incidents" class="stack-form admin-form-grid">
                    <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                    <label>Status
                        <select name="status">
                            <option value="open" {{if eq .AdminIncident.Status "open"}}selected{{end}}>open</option>
                            <option value="mitigated" {{if eq .AdminIncident.Status "mitigated"}}selected{{end}}>mitigated</option>
                            <option value="resolved" {{if eq .AdminIncident.Status "resolved"}}selected{{end}}>resolved</option>
                        </select>
                    </label>
                    <label>Owner
                        <select name="owner_user_id">
                            <option value="">unassigned</option>
                            {{range .AdminUsers}}
                            <option value="{{.ID}}" {{if ownerSelected $.AdminIncident.OwnerUserID .ID}}selected{{end}}>{{.Username}}</option>
                            {{end}}
                        </select>
                    </label>
                    <label class="admin-form-span-2">Impact<textarea name="impact" rows="2">{{.AdminIncident.Impact}}</textarea></label>
                    <label class="admin-form-span-2">Response notes<textarea name="response_notes" rows="6">{{.AdminIncident.ResponseNotes}}</textarea></label>
                    <button type="submit" class="primary-btn">Save response</button>
                </form>
            </article>
            <article class="scenario-card">
                <h3>Operational links</h3>
                <div class="quick-action-list">
                    <a href="/admin/incidents/{{.AdminIncident.ID}}/postmortem">Open postmortem</a>
                    <a href="/admin/incidents/list">Incident list</a>
                    <a href="/admin/audit">{{tr .Locale "admin.incidents_action_audit"}}</a>
                </div>
            </article>
        </div>
        {{else}}
        <p class="muted">Incident record not found.</p>
        {{end}}
        {{else if eq .AdminIncidentsMode "postmortem"}}
        {{if .AdminIncident}}
        <div class="scenario-grid">
            <article class="scenario-card">
                <h3>Incident #{{.AdminIncident.ID}} postmortem</h3>
                <p class="muted">{{.AdminIncident.Title}}</p>
                <form method="post" action="/admin/incidents/{{.AdminIncident.ID}}/postmortem?section=incidents" class="stack-form admin-form-grid">
                    <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                    <label>Status
                        <select name="status">
                            <option value="open" {{if eq .AdminIncident.Status "open"}}selected{{end}}>open</option>
                            <option value="mitigated" {{if eq .AdminIncident.Status "mitigated"}}selected{{end}}>mitigated</option>
                            <option value="resolved" {{if eq .AdminIncident.Status "resolved"}}selected{{end}}>resolved</option>
                        </select>
                    </label>
                    <label class="admin-form-span-2">Postmortem<textarea name="postmortem" rows="10" required>{{.AdminIncident.Postmortem}}</textarea></label>
                    <button type="submit" class="primary-btn">Save postmortem</button>
                </form>
            </article>
            <article class="scenario-card">
                <h3>Follow-up routing</h3>
                <div class="quick-action-list">
                    <a href="/admin/incidents/{{.AdminIncident.ID}}/response">Open response console</a>
                    <a href="/admin/incidents/list">Incident list</a>
                </div>
            </article>
        </div>
        {{else}}
        <p class="muted">Incident record not found.</p>
        {{end}}
        {{else if eq .AdminIncidentsMode "list"}}
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Owner</th>
                        <th>Detected</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminIncidents}}
                    {{range .AdminIncidents}}
                    <tr>
                        <td>#{{.ID}}</td>
                        <td>{{.Title}}</td>
                        <td>{{toUpper (printf "%s" .Severity)}}</td>
                        <td>{{toUpper (printf "%s" .Status)}}</td>
                        <td>{{if .OwnerUser}}{{.OwnerUser.Username}}{{else}}-{{end}}</td>
                        <td>{{formatDateTime .DetectedAt}}</td>
                        <td>
                            <div class="row-actions">
                                <a class="ghost-btn" href="/admin/incidents/{{.ID}}/response">Response</a>
                                <a class="ghost-btn" href="/admin/incidents/{{.ID}}/postmortem">Postmortem</a>
                            </div>
                        </td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="7">No incidents yet.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else}}
        <form method="post" action="/admin/incidents/create?section=incidents" class="stack-form admin-form-grid">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <label>Title<input type="text" name="title" maxlength="160" required></label>
            <label>Severity
                <select name="severity">
                    <option value="medium">medium</option>
                    <option value="low">low</option>
                    <option value="high">high</option>
                    <option value="critical">critical</option>
                </select>
            </label>
            <label>Source<input type="text" name="source" maxlength="128" placeholder="scheduler / webhook / user-report"></label>
            <label>Owner
                <select name="owner_user_id">
                    <option value="">unassigned</option>
                    {{range .AdminUsers}}
                    <option value="{{.ID}}">{{.Username}}</option>
                    {{end}}
                </select>
            </label>
            <label class="admin-form-span-2">Impact<textarea name="impact" rows="2" maxlength="1024"></textarea></label>
            <label class="admin-form-span-2">Summary<textarea name="summary" rows="4" maxlength="2048"></textarea></label>
            <button type="submit" class="primary-btn">Create incident</button>
        </form>
        <div class="quick-action-list">
            <a href="/admin/audit">{{tr .Locale "admin.incidents_action_audit"}}</a>
            <a href="/admin/incidents/list">Incident list</a>
            <a href="/admin/records/sync-jobs">{{tr .Locale "admin.incidents_action_sync"}}</a>
        </div>
        {{end}}
    </section>
    {{end}}

    {{if eq $adminSection "ops"}}
    <section class="panel" id="admin-ops">
        <h2>Operations and Compliance</h2>
        {{if eq .AdminOpsMode "alerts"}}
        <p class="muted">Derived alerts from operational baseline thresholds.</p>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Severity</th>
                        <th>Triggered</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminOpsAlerts}}
                    {{range .AdminOpsAlerts}}
                    <tr>
                        <td>{{.Code}}</td>
                        <td>{{toUpper (printf "%s" .Severity)}}</td>
                        <td>{{if .Triggered}}YES{{else}}NO{{end}}</td>
                        <td>{{.Message}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="4">No alerts available.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else if eq .AdminOpsMode "release-gates"}}
        <p class="muted">Run and review release readiness checks for operational governance.</p>
        <div class="meta-row">
            <span>Result: {{if .AdminOpsReleaseGates.Passed}}PASS{{else}}FAIL{{end}}</span>
            <span>Generated: {{if .AdminOpsReleaseGates.GeneratedAt.IsZero}}N/A{{else}}{{formatDateTime .AdminOpsReleaseGates.GeneratedAt}}{{end}}</span>
        </div>
        <form method="post" action="/api/v1/admin/ops/release-gates/run" class="inline-form">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <button type="submit" class="primary-btn">Run release gate checks</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Severity</th>
                        <th>Passed</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminOpsReleaseGates.Checks}}
                    {{range .AdminOpsReleaseGates.Checks}}
                    <tr>
                        <td>{{.Code}}</td>
                        <td>{{toUpper (printf "%s" .Severity)}}</td>
                        <td>{{if .Passed}}YES{{else}}NO{{end}}</td>
                        <td>{{.Message}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="4">No gate checks available.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else if eq .AdminOpsMode "recovery-drills"}}
        <p class="muted">Record monthly backup and recovery drill outcomes against RPO/RTO targets.</p>
        <form method="post" action="/api/v1/admin/ops/recovery-drills/run" class="stack-form admin-form-grid">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <label>RPO hours<input type="number" min="0.1" step="0.1" name="rpo_hours" value="1.0"></label>
            <label>RTO hours<input type="number" min="0.1" step="0.1" name="rto_hours" value="4.0"></label>
            <label>Occurred at<input type="date" name="occurred_at"></label>
            <label class="admin-form-span-2">Note<textarea name="note" rows="2" maxlength="512"></textarea></label>
            <button type="submit" class="primary-btn">Record recovery drill</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Logged at</th>
                        <th>Actor</th>
                        <th>RPO (h)</th>
                        <th>RTO (h)</th>
                        <th>Passed</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminOpsRecoveryDrills}}
                    {{range .AdminOpsRecoveryDrills}}
                    <tr>
                        <td>{{formatDateTime .LoggedAt}}</td>
                        <td>#{{.ActorUserID}}</td>
                        <td>{{printf "%.2f" .RPOHours}}</td>
                        <td>{{printf "%.2f" .RTOHours}}</td>
                        <td>{{if .Passed}}YES{{else}}NO{{end}}</td>
                        <td>{{.Note}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="6">No recovery drill records.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else if eq .AdminOpsMode "releases"}}
        <p class="muted">Track release timeline and change ticket linkage for each production publish.</p>
        <form method="post" action="/api/v1/admin/ops/releases" class="stack-form admin-form-grid">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <label>Version<input type="text" name="version" maxlength="64" required></label>
            <label>Environment<input type="text" name="environment" value="production" maxlength="64" required></label>
            <label>Change ticket<input type="text" name="change_ticket" maxlength="128"></label>
            <label>Status
                <select name="status">
                    <option value="released">released</option>
                    <option value="planned">planned</option>
                    <option value="rolled-back">rolled-back</option>
                    <option value="failed">failed</option>
                </select>
            </label>
            <label>Released at<input type="date" name="released_at"></label>
            <label class="admin-form-span-2">Note<textarea name="note" rows="2" maxlength="512"></textarea></label>
            <button type="submit" class="primary-btn">Record release</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Released at</th>
                        <th>Version</th>
                        <th>Environment</th>
                        <th>Change ticket</th>
                        <th>Status</th>
                        <th>Actor</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminOpsReleases}}
                    {{range .AdminOpsReleases}}
                    <tr>
                        <td>{{formatDateTime .ReleasedAt}}</td>
                        <td>{{.Version}}</td>
                        <td>{{.Environment}}</td>
                        <td>{{.ChangeTicket}}</td>
                        <td>{{.Status}}</td>
                        <td>#{{.ActorUserID}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="6">No release records.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else if eq .AdminOpsMode "change-approvals"}}
        <p class="muted">Capture reviewer decisions for change control and release accountability.</p>
        <form method="post" action="/api/v1/admin/ops/change-approvals" class="stack-form admin-form-grid">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <label>Ticket ID<input type="text" name="ticket_id" maxlength="128" required></label>
            <label>Reviewer<input type="text" name="reviewer" maxlength="128"></label>
            <label>Status
                <select name="status">
                    <option value="approved">approved</option>
                    <option value="pending">pending</option>
                    <option value="rejected">rejected</option>
                </select>
            </label>
            <label>Occurred at<input type="date" name="occurred_at"></label>
            <label class="admin-form-span-2">Note<textarea name="note" rows="2" maxlength="512"></textarea></label>
            <button type="submit" class="primary-btn">Record approval</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Occurred at</th>
                        <th>Ticket ID</th>
                        <th>Reviewer</th>
                        <th>Status</th>
                        <th>Actor</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminOpsChangeApprovals}}
                    {{range .AdminOpsChangeApprovals}}
                    <tr>
                        <td>{{formatDateTime .OccurredAt}}</td>
                        <td>{{.TicketID}}</td>
                        <td>{{.Reviewer}}</td>
                        <td>{{.Status}}</td>
                        <td>#{{.ActorUserID}}</td>
                        <td>{{.Note}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="6">No change approval records.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else if eq .AdminOpsMode "backup-plans"}}
        <p class="muted">Define backup schedules and retention policy baseline.</p>
        <form method="post" action="/api/v1/admin/ops/backup/plans" class="stack-form admin-form-grid">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <label>Plan key<input type="text" name="plan_key" maxlength="64" required></label>
            <label>Backup type
                <select name="backup_type">
                    <option value="full">full</option>
                    <option value="incremental">incremental</option>
                </select>
            </label>
            <label>Schedule<input type="text" name="schedule" value="0 2 * * *" maxlength="128" required></label>
            <label>Retention days<input type="number" name="retention_days" min="1" step="1" value="30" required></label>
            <label>Enabled
                <select name="enabled">
                    <option value="true">true</option>
                    <option value="false">false</option>
                </select>
            </label>
            <label>Occurred at<input type="date" name="occurred_at"></label>
            <label class="admin-form-span-2">Note<textarea name="note" rows="2" maxlength="512"></textarea></label>
            <button type="submit" class="primary-btn">Save backup plan</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Logged at</th>
                        <th>Plan key</th>
                        <th>Type</th>
                        <th>Schedule</th>
                        <th>Retention</th>
                        <th>Enabled</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminOpsBackupPlans}}
                    {{range .AdminOpsBackupPlans}}
                    <tr>
                        <td>{{formatDateTime .LoggedAt}}</td>
                        <td>{{.PlanKey}}</td>
                        <td>{{.BackupType}}</td>
                        <td>{{.Schedule}}</td>
                        <td>{{.RetentionDays}} days</td>
                        <td>{{if .Enabled}}YES{{else}}NO{{end}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="6">No backup plan records.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else if eq .AdminOpsMode "backup-runs"}}
        <p class="muted">Track backup execution runs and recovery evidence for audit windows.</p>
        <form method="post" action="/api/v1/admin/ops/backup/runs" class="stack-form admin-form-grid">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <label>Plan key<input type="text" name="plan_key" maxlength="64" required></label>
            <label>Status
                <select name="status">
                    <option value="succeeded">succeeded</option>
                    <option value="failed">failed</option>
                    <option value="running">running</option>
                </select>
            </label>
            <label>Size MB<input type="number" min="0" step="0.1" name="size_mb" value="0"></label>
            <label>Duration minutes<input type="number" min="0" step="0.1" name="duration_minutes" value="0"></label>
            <label>Occurred at<input type="date" name="occurred_at"></label>
            <label class="admin-form-span-2">Note<textarea name="note" rows="2" maxlength="512"></textarea></label>
            <button type="submit" class="primary-btn">Record backup run</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Logged at</th>
                        <th>Plan key</th>
                        <th>Status</th>
                        <th>Size MB</th>
                        <th>Duration minutes</th>
                        <th>Actor</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminOpsBackupRuns}}
                    {{range .AdminOpsBackupRuns}}
                    <tr>
                        <td>{{formatDateTime .LoggedAt}}</td>
                        <td>{{.PlanKey}}</td>
                        <td>{{.Status}}</td>
                        <td>{{printf "%.2f" .SizeMB}}</td>
                        <td>{{printf "%.2f" .DurationMinutes}}</td>
                        <td>#{{.ActorUserID}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="6">No backup run records.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else if eq .AdminOpsMode "audit-export"}}
        <p class="muted">Export audit logs by time window in JSON or CSV format.</p>
        <form method="get" action="/api/v1/admin/ops/audit-export" class="stack-form admin-form-grid">
            <label>From<input type="date" name="from"></label>
            <label>To<input type="date" name="to"></label>
            <label>Format
                <select name="format">
                    <option value="json">json</option>
                    <option value="csv">csv</option>
                </select>
            </label>
            <button type="submit" class="primary-btn">Download export</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Actor</th>
                        <th>Action</th>
                        <th>Target</th>
                        <th>Summary</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AuditLogs}}
                    {{range .AuditLogs}}
                    <tr>
                        <td>{{formatDateTime .CreatedAt}}</td>
                        <td>{{if .ActorUser}}{{.ActorUser.Username}}{{else}}#{{.ActorUserID}}{{end}}</td>
                        <td>{{.Action}}</td>
                        <td>{{.TargetType}}#{{.TargetID}}</td>
                        <td>{{.Summary}}</td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="5">No audit logs in preview.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="admin-ops-shell admin-ops-shell-metrics">
            <header class="admin-ops-header">
                <div>
                    <p class="admin-ops-kicker">Operations Snapshot</p>
                    <h3>Live reliability baseline</h3>
                    <p class="muted">Operational baseline metrics over the latest 24 hour activity window.</p>
                </div>
                <div class="admin-ops-header-meta">
                    <span>Generated: {{formatDateTime .AdminOpsMetrics.GeneratedAt}}</span>
                    <span>Retention baseline: {{.AdminOpsMetrics.RetentionDays}} days</span>
                </div>
            </header>

            <div class="admin-ops-kpi-grid">
                <article class="admin-ops-kpi">
                    <span class="admin-ops-kpi-label">Request QPS</span>
                    <strong class="admin-ops-kpi-value">{{printf "%.2f" .AdminOpsMetrics.RequestQPS}}</strong>
                    <span class="admin-ops-kpi-note">Current throughput baseline</span>
                </article>
                <article class="admin-ops-kpi">
                    <span class="admin-ops-kpi-label">P95 latency</span>
                    <strong class="admin-ops-kpi-value">{{printf "%.2f ms" .AdminOpsMetrics.LatencyP95Ms}}</strong>
                    <span class="admin-ops-kpi-note">Tail latency across request traces</span>
                </article>
                <article class="admin-ops-kpi">
                    <span class="admin-ops-kpi-label">Sync success rate</span>
                    <strong class="admin-ops-kpi-value">{{printf "%.2f%%" .AdminOpsMetrics.SyncSuccessRate}}</strong>
                    <span class="admin-ops-kpi-note">From {{.AdminOpsMetrics.TotalSyncRuns24h}} sync runs in 24h</span>
                </article>
                <article class="admin-ops-kpi">
                    <span class="admin-ops-kpi-label">Audit write failure</span>
                    <strong class="admin-ops-kpi-value">{{printf "%.2f%%" .AdminOpsMetrics.AuditWriteFailureRate}}</strong>
                    <span class="admin-ops-kpi-note">Failure percentage for audit persistence</span>
                </article>
            </div>

            <div class="admin-ops-signal-grid">
                <article class="admin-ops-signal-card">
                    <h4>Latency profile</h4>
                    <p class="muted">Review percentile spread to validate response stability.</p>
                    <dl class="admin-ops-inline-stats">
                        <div><dt>P50 latency</dt><dd>{{printf "%.2f ms" .AdminOpsMetrics.LatencyP50Ms}}</dd></div>
                        <div><dt>P95 latency</dt><dd>{{printf "%.2f ms" .AdminOpsMetrics.LatencyP95Ms}}</dd></div>
                        <div><dt>P99 latency</dt><dd>{{printf "%.2f ms" .AdminOpsMetrics.LatencyP99Ms}}</dd></div>
                    </dl>
                </article>
                <article class="admin-ops-signal-card">
                    <h4>Error profile</h4>
                    <p class="muted">Monitor client and server error ratio to control reliability drift.</p>
                    <dl class="admin-ops-inline-stats">
                        <div><dt>4xx error rate</dt><dd>{{printf "%.2f%%" .AdminOpsMetrics.ErrorRate4xx}}</dd></div>
                        <div><dt>5xx error rate</dt><dd>{{printf "%.2f%%" .AdminOpsMetrics.ErrorRate5xx}}</dd></div>
                        <div><dt>Sync failure count</dt><dd>{{.AdminOpsMetrics.FailedSyncRuns24h}}</dd></div>
                    </dl>
                </article>
                <article class="admin-ops-signal-card">
                    <h4>Audit and sync volume</h4>
                    <p class="muted">Confirm observability and governance coverage over operational activity.</p>
                    <dl class="admin-ops-inline-stats">
                        <div><dt>Audit logs in 24h</dt><dd>{{.AdminOpsMetrics.TotalAuditLogs24h}}</dd></div>
                        <div><dt>Sync runs in 24h</dt><dd>{{.AdminOpsMetrics.TotalSyncRuns24h}}</dd></div>
                        <div><dt>Retention baseline</dt><dd>{{.AdminOpsMetrics.RetentionDays}} days</dd></div>
                    </dl>
                </article>
            </div>
        </div>
        {{end}}
    </section>
    {{end}}

    {{if eq $adminSection "records"}}
    <section class="panel" id="admin-records">
        <h2>{{tr .Locale "admin.records"}}</h2>
        {{if eq .AdminRecordsMode "imports"}}
        <p class="muted">Import operation records are highlighted in this view.</p>
        {{else if eq .AdminRecordsMode "sync-jobs"}}
        <p class="muted">Sync job operations are highlighted in this view.</p>
        {{else if eq .AdminRecordsMode "exports"}}
        <p class="muted">Export operation records are highlighted in this view.</p>
        {{else}}
        <p class="muted">Browse all records and apply source, keyword, and visibility filters.</p>
        {{end}}
        <div class="admin-record-actions">
            <form method="post" action="/admin/sync/repositories?section=records{{if eq .AdminRecordsMode "sync-jobs"}}&subsection=sync-jobs{{end}}" class="inline-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <input type="hidden" name="scope" value="{{if canViewAllSkills .CurrentUser}}all{{else}}owned{{end}}">
                <input type="hidden" name="limit" value="50">
                <button type="submit" class="ghost-btn">{{tr .Locale "admin.sync_repositories_now"}}</button>
            </form>
            <p class="muted">{{tr .Locale "admin.sync_repositories_note"}}</p>
        </div>
        {{if eq .AdminRecordsMode "sync-jobs"}}
        <div class="scenario-grid">
            <article class="scenario-card">
                <h3>{{tr .Locale "admin.sync_policy_title"}}</h3>
                <p class="muted">{{tr .Locale "admin.sync_policy_summary"}}</p>
                <div class="meta-row">
                    <span>{{tr .Locale "admin.sync_policy_enabled"}}: {{if .AdminSyncPolicy.Enabled}}{{tr .Locale "admin.sync_policy_enabled_on"}}{{else}}{{tr .Locale "admin.sync_policy_enabled_off"}}{{end}}</span>
                    <span>{{tr .Locale "admin.sync_policy_interval"}}: {{.AdminSyncPolicy.Interval}}</span>
                    <span>{{tr .Locale "admin.sync_policy_timeout"}}: {{.AdminSyncPolicy.Timeout}}</span>
                    <span>{{tr .Locale "admin.sync_policy_batch_size"}}: {{.AdminSyncPolicy.BatchSize}}</span>
                </div>
                <form method="post" action="/admin/sync-policy/repository?section=records&subsection=sync-jobs" class="stack-form admin-form-grid">
                    <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                    <label>{{tr .Locale "admin.sync_policy_enabled"}}
                        <select name="enabled">
                            <option value="true" {{if .AdminSyncPolicy.Enabled}}selected{{end}}>{{tr .Locale "admin.sync_policy_enabled_on"}}</option>
                            <option value="false" {{if not .AdminSyncPolicy.Enabled}}selected{{end}}>{{tr .Locale "admin.sync_policy_enabled_off"}}</option>
                        </select>
                    </label>
                    <label>{{tr .Locale "admin.sync_policy_interval"}}<input type="text" name="interval" value="{{.AdminSyncPolicy.Interval}}" required></label>
                    <label>{{tr .Locale "admin.sync_policy_timeout"}}<input type="text" name="timeout" value="{{.AdminSyncPolicy.Timeout}}" required></label>
                    <label>{{tr .Locale "admin.sync_policy_batch_size"}}<input type="number" name="batch_size" min="1" value="{{.AdminSyncPolicy.BatchSize}}" required></label>
                    <button type="submit" class="primary-btn">{{tr .Locale "admin.sync_policy_update"}}</button>
                </form>
            </article>
            <article class="scenario-card">
                <h3>{{tr .Locale "admin.sync_jobs_detail_title"}}</h3>
                {{if .AdminSyncRunDetail}}
                <p class="muted">{{tr .Locale "admin.sync_jobs_detail_summary"}} #{{.AdminSyncRunDetail.ID}}</p>
                <p class="muted">Trigger: {{toUpper .AdminSyncRunDetail.Trigger}} · Scope: {{toUpper .AdminSyncRunDetail.Scope}}</p>
                <p class="muted">Status: {{toUpper .AdminSyncRunDetail.Status}} · Duration: {{.AdminSyncRunDetail.DurationMs}} ms</p>
                <p class="muted">Candidates: {{.AdminSyncRunDetail.Candidates}} · Synced: {{.AdminSyncRunDetail.Synced}} · Failed: {{.AdminSyncRunDetail.Failed}}</p>
                <p class="muted">Actor: {{if .AdminSyncRunDetail.ActorUser}}{{.AdminSyncRunDetail.ActorUser.Username}}{{else}}SYSTEM{{end}}</p>
                <p class="muted">Owner: {{if .AdminSyncRunDetail.OwnerUser}}{{.AdminSyncRunDetail.OwnerUser.Username}}{{else}}-{{end}}</p>
                <p class="muted">Started: {{formatDateTime .AdminSyncRunDetail.StartedAt}}</p>
                <p class="muted">Finished: {{formatDateTime .AdminSyncRunDetail.FinishedAt}}</p>
                {{if .AdminSyncRunDetail.ErrorSummary}}<p class="muted">Error: {{.AdminSyncRunDetail.ErrorSummary}}</p>{{end}}
                {{else}}
                <p class="muted">{{tr .Locale "admin.sync_jobs_detail_empty"}}</p>
                {{end}}
            </article>
            <article class="scenario-card">
                <h3>Async Job Detail</h3>
                {{if .AdminAsyncJobDetail}}
                <p class="muted">Selected async job #{{.AdminAsyncJobDetail.ID}}</p>
                <p class="muted">Type: {{toUpper (printf "%s" .AdminAsyncJobDetail.JobType)}} · Status: {{toUpper (printf "%s" .AdminAsyncJobDetail.Status)}}</p>
                <p class="muted">Attempt: {{.AdminAsyncJobDetail.Attempt}} / {{.AdminAsyncJobDetail.MaxAttempts}}</p>
                <p class="muted">Owner: {{if .AdminAsyncJobDetail.OwnerUser}}{{.AdminAsyncJobDetail.OwnerUser.Username}}{{else}}-{{end}}</p>
                <p class="muted">Actor: {{if .AdminAsyncJobDetail.ActorUser}}{{.AdminAsyncJobDetail.ActorUser.Username}}{{else}}-{{end}}</p>
                <p class="muted">Created: {{formatDateTime .AdminAsyncJobDetail.CreatedAt}}</p>
                <p class="muted">Started: {{if .AdminAsyncJobDetail.StartedAt}}{{formatTimePtr .AdminAsyncJobDetail.StartedAt}}{{else}}-{{end}}</p>
                <p class="muted">Finished: {{if .AdminAsyncJobDetail.FinishedAt}}{{formatTimePtr .AdminAsyncJobDetail.FinishedAt}}{{else}}-{{end}}</p>
                {{if .AdminAsyncJobDetail.ErrorMessage}}<p class="muted">Error: {{.AdminAsyncJobDetail.ErrorMessage}}</p>{{end}}
                <div class="row-actions">
                    {{if or (eq .AdminAsyncJobDetail.Status "failed") (eq .AdminAsyncJobDetail.Status "canceled")}}
                    <form method="post" action="/admin/jobs/{{.AdminAsyncJobDetail.ID}}/retry" class="inline-form">
                        <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                        <button type="submit" class="ghost-btn">Retry</button>
                    </form>
                    {{end}}
                    {{if or (eq .AdminAsyncJobDetail.Status "pending") (eq .AdminAsyncJobDetail.Status "running")}}
                    <form method="post" action="/admin/jobs/{{.AdminAsyncJobDetail.ID}}/cancel" class="inline-form">
                        <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                        <button type="submit" class="ghost-btn">Cancel</button>
                    </form>
                    {{end}}
                </div>
                {{else}}
                <p class="muted">Select one async job from the table to inspect status transition details.</p>
                {{end}}
            </article>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Created</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Attempt</th>
                        <th>Owner</th>
                        <th>Actor</th>
                        <th>Error</th>
                        <th>{{tr .Locale "admin.table_actions"}}</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminAsyncJobs}}
                    {{range .AdminAsyncJobs}}
                    <tr>
                        <td>{{formatDateTime .CreatedAt}}</td>
                        <td>{{toUpper (printf "%s" .JobType)}}</td>
                        <td>{{toUpper (printf "%s" .Status)}}</td>
                        <td>{{.Attempt}} / {{.MaxAttempts}}</td>
                        <td>{{if .OwnerUser}}{{.OwnerUser.Username}}{{else}}-{{end}}</td>
                        <td>{{if .ActorUser}}{{.ActorUser.Username}}{{else}}-{{end}}</td>
                        <td>{{if .ErrorMessage}}{{.ErrorMessage}}{{else}}-{{end}}</td>
                        <td>
                            <div class="row-actions">
                                <a class="ghost-btn" href="/admin/jobs/{{.ID}}">Detail</a>
                                {{if or (eq .Status "failed") (eq .Status "canceled")}}
                                <form method="post" action="/admin/jobs/{{.ID}}/retry" class="inline-form">
                                    <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                                    <button type="submit" class="ghost-btn">Retry</button>
                                </form>
                                {{end}}
                                {{if or (eq .Status "pending") (eq .Status "running")}}
                                <form method="post" action="/admin/jobs/{{.ID}}/cancel" class="inline-form">
                                    <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                                    <button type="submit" class="ghost-btn">Cancel</button>
                                </form>
                                {{end}}
                            </div>
                        </td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="8">No async jobs recorded.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Started</th>
                        <th>Duration</th>
                        <th>Trigger</th>
                        <th>Scope</th>
                        <th>Status</th>
                        <th>Candidates</th>
                        <th>Synced</th>
                        <th>Failed</th>
                        <th>Actor</th>
                        <th>Error</th>
                        <th>{{tr .Locale "admin.table_actions"}}</th>
                    </tr>
                </thead>
                <tbody>
                {{if .AdminSyncRuns}}
                    {{range .AdminSyncRuns}}
                    <tr>
                        <td>{{formatDateTime .StartedAt}}</td>
                        <td>{{.DurationMs}} ms</td>
                        <td>{{toUpper .Trigger}}</td>
                        <td>{{toUpper .Scope}}</td>
                        <td>{{toUpper .Status}}</td>
                        <td>{{.Candidates}}</td>
                        <td>{{.Synced}}</td>
                        <td>{{.Failed}}</td>
                        <td>{{if .ActorUser}}{{.ActorUser.Username}}{{else}}SYSTEM{{end}}</td>
                        <td>{{if .ErrorSummary}}{{.ErrorSummary}}{{else}}-{{end}}</td>
                        <td><a class="ghost-btn" href="/admin/records/sync-jobs?run_id={{.ID}}">{{tr $.Locale "admin.sync_jobs_open_detail"}}</a></td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="11">No sync jobs recorded.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="admin-record-tools">
            <label>{{tr .Locale "admin.records_filter_keyword"}}
                <input type="text" id="skill-record-filter" placeholder="{{tr .Locale "admin.records_filter_keyword_placeholder"}}">
            </label>
            <label>{{tr .Locale "admin.records_filter_source"}}
                <select id="skill-record-source">
                    <option value="all">{{tr .Locale "admin.filter_all"}}</option>
                    <option value="manual">MANUAL</option>
                    <option value="upload">UPLOAD</option>
                    <option value="repository">REPOSITORY</option>
                    <option value="skillmp">SKILLMP</option>
                </select>
            </label>
            <label>{{tr .Locale "admin.records_filter_visibility"}}
                <select id="skill-record-visibility">
                    <option value="all">{{tr .Locale "admin.filter_all"}}</option>
                    <option value="public">PUBLIC</option>
                    <option value="private">PRIVATE</option>
                </select>
            </label>
        </div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>{{tr .Locale "admin.table_name"}}</th>
                        {{if .AdminShowOwner}}<th>{{tr .Locale "admin.table_owner"}}</th>{{end}}
                        <th>{{tr .Locale "admin.table_category"}}</th>
                        <th>{{tr .Locale "admin.table_source"}}</th>
                        <th>{{tr .Locale "admin.table_stars"}}</th>
                        <th>{{tr .Locale "admin.table_visibility"}}</th>
                        <th>{{tr .Locale "admin.table_updated"}}</th>
                        <th>{{tr .Locale "admin.table_actions"}}</th>
                    </tr>
                </thead>
                <tbody>
                {{if .UserSkills}}
                {{range .UserSkills}}
                <tr data-skill-row data-name="{{.Name}}" data-owner="{{.Owner.Username}}" data-category="{{.CategorySlug}} {{.SubcategorySlug}}" data-source="{{.SourceType}}" data-visibility="{{.Visibility}}">
                    <td><a href="/skills/{{.ID}}">{{.Name}}</a></td>
                    {{if $.AdminShowOwner}}<td>{{.Owner.Username}}</td>{{end}}
                    <td>{{.CategorySlug}} / {{.SubcategorySlug}}</td>
                    <td>{{.SourceType}}</td>
                    <td>{{.StarCount}}</td>
                    <td>{{.Visibility}}</td>
                    <td>{{formatTime .UpdatedAt}}</td>
                    <td>
                        <div class="row-actions">
                            <form method="post" action="/skills/{{.ID}}/visibility?section=records" class="inline-form">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                                <select name="visibility"><option value="private" {{if eq .Visibility "private"}}selected{{end}}>{{tr $.Locale "admin.visibility_private"}}</option><option value="public" {{if eq .Visibility "public"}}selected{{end}}>{{tr $.Locale "admin.visibility_public"}}</option></select>
                                <button type="submit" class="ghost-btn">{{tr $.Locale "admin.action_save"}}</button>
                            </form>
                            {{if isSyncable .SourceType}}
                            <form method="post" action="/skills/{{.ID}}/sync?section=records" class="inline-form">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                                <button type="submit" class="ghost-btn">{{tr $.Locale "admin.action_sync"}}</button>
                            </form>
                            {{end}}
                            <a class="ghost-btn" href="/skills/{{.ID}}/versions">{{tr $.Locale "admin.action_history"}}</a>
                            <form method="post" action="/skills/{{.ID}}/delete?section=records" class="inline-form" onsubmit="return confirm('{{tr $.Locale "admin.confirm_delete_skill"}}');">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                                <button type="submit" class="danger-btn">{{tr $.Locale "admin.action_delete"}}</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {{end}}
                {{else}}
                <tr>
                    <td {{if .AdminShowOwner}}colspan="8"{{else}}colspan="7"{{end}}>{{tr .Locale "admin.empty_records"}}</td>
                </tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{end}}
