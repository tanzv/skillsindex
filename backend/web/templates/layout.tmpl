            <h2>Password Security</h2>
            <p class="muted">Changing password can optionally revoke all other active sessions.</p>
            <form method="post" action="/account/security/password" class="stack-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <label>Current Password<input type="password" name="current_password" autocomplete="current-password" required minlength="8" maxlength="128"></label>
                <label>New Password<input type="password" name="new_password" autocomplete="new-password" required minlength="8" maxlength="128"></label>
                <label class="checkbox-field">
                    <input type="checkbox" name="revoke_other_sessions" value="true">
                    <span>Revoke all other sessions after password update</span>
                </label>
                <button type="submit" class="primary-btn">Update Password</button>
            </form>
        </article>
        {{else if eq .AccountSection "sessions"}}
        <article class="panel">
            <h2>Session Overview</h2>
            <div class="table-wrap">
                <table class="admin-table">
                    <tbody>
                        <tr>
                            <th>Current Session Issued At</th>
                            <td>{{if .AccountSessionIssued}}{{formatTimePtr .AccountSessionIssued}}{{else}}Unknown{{end}}</td>
                        </tr>
                        <tr>
                            <th>Current Session Expires At</th>
                            <td>{{if .AccountSessionExpires}}{{formatTimePtr .AccountSessionExpires}}{{else}}Unknown{{end}}</td>
                        </tr>
                        <tr>
                            <th>Current Session ID</th>
                            <td>{{if .AccountCurrentSessionID}}{{sessionLabel .AccountCurrentSessionID}}{{else}}Unknown{{end}}</td>
                        </tr>
                        <tr>
                            <th>Global Force Signout Timestamp</th>
                            <td>{{if .CurrentUser.ForceLogoutAt}}{{formatTimePtr .CurrentUser.ForceLogoutAt}}{{else}}Not set{{end}}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Session</th>
                            <th>Created</th>
                            <th>Last Seen</th>
                            <th>Expires</th>
                            <th>Client</th>
                            <th>IP</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{if .AccountSessions}}
                            {{range .AccountSessions}}
                            <tr>
                                <td>{{sessionLabel .SessionID}}{{if eq $.AccountCurrentSessionID .SessionID}} <span class="badge">CURRENT</span>{{end}}</td>
                                <td>{{formatDateTime .CreatedAt}}</td>
                                <td>{{formatDateTime .LastSeenAt}}</td>
                                <td>{{formatDateTime .ExpiresAt}}</td>
                                <td>{{if .UserAgent}}{{.UserAgent}}{{else}}Unknown{{end}}</td>
                                <td>{{if .IssuedIP}}{{.IssuedIP}}{{else}}Unknown{{end}}</td>
                                <td>
                                    {{if ne $.AccountCurrentSessionID .SessionID}}
                                    <form method="post" action="/account/sessions/{{.SessionID}}/revoke" class="inline-form" onsubmit="return confirm('Revoke this session?');">
                                        <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                                        <button type="submit" class="ghost-btn">Revoke</button>
                                    </form>
                                    {{else}}
                                    <span class="muted">Current session</span>
                                    {{end}}
                                </td>
                            </tr>
                            {{end}}
                        {{else}}
                            <tr><td colspan="7">No active session records available.</td></tr>
                        {{end}}
                    </tbody>
                </table>
            </div>
            <form method="post" action="/account/sessions/revoke-others" class="inline-form" onsubmit="return confirm('Revoke other sessions now?');">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <button type="submit" class="ghost-btn">Revoke Other Sessions</button>
            </form>
        </article>
        {{else}}
