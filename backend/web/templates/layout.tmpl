                </article>

                <article class="matrix-card">
                    <h2>{{tr .Locale "detail.version_track"}}</h2>
                    <p class="matrix-text">{{tr .Locale "detail.updated_at"}}: {{formatDateTime .Skill.UpdatedAt}}</p>
                    {{if .Skill.InstallCommand}}
                    <pre class="content-box detail-content-box">{{.Skill.InstallCommand}}</pre>
                    {{end}}
                </article>

                <article class="matrix-card">
                    <h2>{{tr .Locale "detail.usage_snapshot"}}</h2>
                    <pre class="content-box detail-content-box">{{.Skill.Content}}</pre>
                </article>
            </div>

            <aside class="matrix-side-column">
                <article class="matrix-side-card matrix-side-card-highlight">
                    <h2>{{tr .Locale "detail.install_release"}}</h2>
                    {{if .Skill.InstallCommand}}
                    <p class="matrix-text">{{.Skill.InstallCommand}}</p>
                    {{else}}
                    <p class="matrix-text">No install command configured.</p>
                    {{end}}
                </article>

                <article class="matrix-side-card">
                    <h2>{{tr .Locale "detail.metadata"}}</h2>
                    <p class="matrix-text">{{tr .Locale "detail.category"}}: {{.Skill.CategorySlug}}</p>
                    <p class="matrix-text">{{tr .Locale "detail.subcategory"}}: {{.Skill.SubcategorySlug}}</p>
                    <p class="matrix-text">{{tr .Locale "detail.source"}}: {{.Skill.SourceType}}</p>
                </article>

                <article class="matrix-side-card">
                    <h2>{{tr .Locale "detail.action_panel"}}</h2>
                    {{if and .CurrentUser (canAccessDashboard .CurrentUser)}}
                    <div class="row-actions">
                        <form method="post" action="/skills/{{.Skill.ID}}/favorite" class="inline-form">
                            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                            <input type="hidden" name="favorite" value="{{if .DetailFavorited}}off{{else}}on{{end}}">
                            <button type="submit" class="ghost-btn">{{if .DetailFavorited}}{{tr .Locale "detail.favorite_off"}}{{else}}{{tr .Locale "detail.favorite_on"}}{{end}}</button>
                        </form>
                        <form method="post" action="/skills/{{.Skill.ID}}/rating" class="inline-form">
                            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                            <select name="score">
                                <option value="1" {{if eq .DetailUserRating 1}}selected{{end}}>1</option>
                                <option value="2" {{if eq .DetailUserRating 2}}selected{{end}}>2</option>
                                <option value="3" {{if eq .DetailUserRating 3}}selected{{end}}>3</option>
                                <option value="4" {{if eq .DetailUserRating 4}}selected{{end}}>4</option>
                                <option value="5" {{if eq .DetailUserRating 5}}selected{{end}}>5</option>
                            </select>
                            <button type="submit" class="ghost-btn">{{tr .Locale "detail.rate_submit"}}</button>
                        </form>
                    </div>
                    <form method="post" action="/skills/{{.Skill.ID}}/comments" class="stack-form">
                        <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                        <label>{{tr .Locale "detail.comment_label"}}
                            <textarea name="content" rows="3" maxlength="3000" placeholder="{{tr .Locale "detail.comment_placeholder"}}" required></textarea>
                        </label>
                        <div><button type="submit" class="primary-btn">{{tr .Locale "detail.comment_submit"}}</button></div>
                    </form>
                    {{else}}
                    <p class="matrix-text">{{tr .Locale "detail.login_for_interaction"}} <a href="/login">{{tr .Locale "nav.sign_in"}}</a></p>
                    {{end}}
                </article>

                <article class="matrix-side-card">
                    <h2>{{tr .Locale "detail.dependencies"}}</h2>
                    <p class="matrix-text">category/{{.Skill.CategorySlug}}</p>
                    <p class="matrix-text">subcategory/{{.Skill.SubcategorySlug}}</p>
                    <p class="matrix-text">source/{{.Skill.SourceType}}</p>
                </article>
            </aside>
        </div>

        <article class="matrix-card detail-comments-card">
            <h2>{{tr .Locale "detail.comments"}}</h2>
            {{if .DetailComments}}
                {{range .DetailComments}}
                <article class="comment-card">
                    <p class="muted">{{.User.Username}} · {{formatDateTime .CreatedAt}}</p>
                    <p>{{.Content}}</p>
                    {{if and $.CurrentUser ($.CurrentUser.CanDeleteComment .UserID)}}
                    <form method="post" action="/skills/{{$.Skill.ID}}/comments/{{.ID}}/delete" class="inline-form">
                        <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                        <button type="submit" class="danger-btn">{{tr $.Locale "detail.comment_delete"}}</button>
                    </form>
                    {{end}}
                </article>
                {{end}}
            {{else}}
                <p class="empty">{{tr .Locale "detail.comment_empty"}}</p>
            {{end}}
        </article>
    </section>
    {{end}}

    {{if eq .Page "skill_versions"}}
    <section class="panel" id="skill-version-history">
        {{if .Skill}}
        <div class="section-head">
            <h2>Version History: {{.Skill.Name}}</h2>
            <div class="row-actions">
                <a class="ghost-btn" href="/skills/{{.Skill.ID}}">Back to detail</a>
                <a class="ghost-btn" href="/skills/{{.Skill.ID}}/versions/compare">Compare latest</a>
            </div>
        </div>
        <form method="get" action="/skills/{{.Skill.ID}}/versions" class="inline-form">
            <label>Trigger <input type="text" name="trigger" value="{{.TagFilter}}" placeholder="sync"></label>
            <label>From <input type="text" name="from_time" placeholder="2026-02-01"></label>
            <label>To <input type="text" name="to_time" placeholder="2026-02-28"></label>
            <label><input type="checkbox" name="include_archived" value="1"> Include archived</label>
            <button type="submit" class="ghost-btn">Apply Filters</button>
        </form>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Version</th>
                        <th>Captured</th>
                        <th>Trigger</th>
                        <th>Actor</th>
                        <th>Status</th>
                        <th>Visibility</th>
                        <th>Source</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {{if .SkillVersions}}
                    {{range .SkillVersions}}
                    <tr>
                        <td>#{{.VersionNumber}}</td>
                        <td>{{formatDateTime .CapturedAt}}</td>
                        <td>{{toUpper .Trigger}}</td>
                        <td>{{if .ActorUser}}{{.ActorUser.Username}}{{else}}SYSTEM{{end}}</td>
                        <td>{{if .ArchivedAt}}ARCHIVED{{else}}ACTIVE{{end}}</td>
                        <td>{{toUpper (printf "%s" .Visibility)}}</td>
                        <td>{{toUpper (printf "%s" .SourceType)}}</td>
                        <td>
                            <a class="ghost-btn" href="/skills/{{$.Skill.ID}}/versions/{{.ID}}">View</a>
                            <a class="ghost-btn" href="/skills/{{$.Skill.ID}}/versions/compare?from={{.ID}}&to={{(index $.SkillVersions 0).ID}}">Compare</a>
                            <form method="post" action="/skills/{{$.Skill.ID}}/versions/{{.ID}}/rollback" class="inline-form" onsubmit="return confirm('Rollback this version as current skill state?');">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">
                                <button type="submit" class="ghost-btn">Rollback</button>
                            </form>
                        </td>
                    </tr>
                    {{end}}
                {{else}}
                    <tr><td colspan="8">No versions available.</td></tr>
                {{end}}
                </tbody>
            </table>
        </div>
        {{else}}
        <p class="muted">Skill not found.</p>
        {{end}}
    </section>
    {{end}}

    {{if eq .Page "skill_version_detail"}}
    <section class="panel" id="skill-version-detail">
        {{if and .Skill .SkillVersionDetail}}
        <div class="section-head">
            <h2>Version #{{.SkillVersionDetail.VersionNumber}}: {{.Skill.Name}}</h2>
            <div class="row-actions">
                <a class="ghost-btn" href="/skills/{{.Skill.ID}}/versions">Back to history</a>
                <a class="ghost-btn" href="/skills/{{.Skill.ID}}/versions/compare?from={{.SkillVersionDetail.ID}}&to={{(index .SkillVersions 0).ID}}">Compare with latest</a>
            </div>
        </div>
        <article class="matrix-card">
            <p class="muted">Captured at {{formatDateTime .SkillVersionDetail.CapturedAt}} by {{if .SkillVersionDetail.ActorUser}}{{.SkillVersionDetail.ActorUser.Username}}{{else}}SYSTEM{{end}}</p>
            <p>Trigger: <strong>{{toUpper .SkillVersionDetail.Trigger}}</strong></p>
            <p>Visibility: {{toUpper (printf "%s" .SkillVersionDetail.Visibility)}} · Source: {{toUpper (printf "%s" .SkillVersionDetail.SourceType)}}</p>
            <p>Category: {{.SkillVersionDetail.CategorySlug}} / {{.SkillVersionDetail.SubcategorySlug}}</p>
            <p>Tags JSON: {{.SkillVersionDetail.TagsJSON}}</p>
            <p><strong>Change Summary</strong>: {{if .SkillVersionDetail.ChangeSummary}}{{.SkillVersionDetail.ChangeSummary}}{{else}}No summary{{end}}</p>
            <p><strong>Risk Level</strong>: {{if .SkillVersionDetail.RiskLevel}}{{toUpper .SkillVersionDetail.RiskLevel}}{{else}}N/A{{end}}</p>
            <p><strong>Before Digest</strong>: {{if .SkillVersionDetail.BeforeDigest}}{{.SkillVersionDetail.BeforeDigest}}{{else}}N/A{{end}}</p>
            <p><strong>After Digest</strong>: {{if .SkillVersionDetail.AfterDigest}}{{.SkillVersionDetail.AfterDigest}}{{else}}N/A{{end}}</p>
            <p><strong>Changed Fields JSON</strong>: {{if .SkillVersionDetail.ChangedFieldsJSON}}{{.SkillVersionDetail.ChangedFieldsJSON}}{{else}}[]{{end}}</p>
            <h3>Snapshot Name</h3>
            <p>{{.SkillVersionDetail.Name}}</p>
            <h3>Description</h3>
            <p>{{.SkillVersionDetail.Description}}</p>
            <h3>Content</h3>
            <pre>{{.SkillVersionDetail.Content}}</pre>
            <form method="post" action="/skills/{{.Skill.ID}}/versions/{{.SkillVersionDetail.ID}}/rollback" class="inline-form" onsubmit="return confirm('Rollback this version as current skill state?');">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <button type="submit" class="ghost-btn">Rollback this version</button>
            </form>
        </article>
        {{else}}
        <p class="muted">Skill version not found.</p>
        {{end}}
    </section>
    {{end}}

    {{if eq .Page "skill_version_compare"}}
    <section class="panel" id="skill-version-compare">
        {{if and .Skill .SkillVersionCompare}}
        <div class="section-head">
            <h2>Version Compare: {{.Skill.Name}}</h2>
            <div class="row-actions">
                <a class="ghost-btn" href="/skills/{{.Skill.ID}}/versions">Back to history</a>
                <a class="ghost-btn" href="/skills/{{.Skill.ID}}/versions/{{.SkillVersionCompare.FromVersion.ID}}">Open from version</a>
                <a class="ghost-btn" href="/skills/{{.Skill.ID}}/versions/{{.SkillVersionCompare.ToVersion.ID}}">Open to version</a>
            </div>
        </div>
        <article class="matrix-card">
            <p><strong>From:</strong> #{{.SkillVersionCompare.FromVersion.VersionNumber}} ({{formatDateTime .SkillVersionCompare.FromVersion.CapturedAt}})</p>
            <p><strong>To:</strong> #{{.SkillVersionCompare.ToVersion.VersionNumber}} ({{formatDateTime .SkillVersionCompare.ToVersion.CapturedAt}})</p>
            <p><strong>Risk level:</strong> {{toUpper .SkillVersionCompare.RiskLevel}}</p>
            <p><strong>Before digest:</strong> {{.SkillVersionCompare.BeforeDigest}}</p>
            <p><strong>After digest:</strong> {{.SkillVersionCompare.AfterDigest}}</p>
            <p><strong>Summary:</strong> {{.SkillVersionCompare.ChangeSummary}}</p>
        </article>
        <article class="matrix-card">
            <h3>Changed Fields</h3>
            {{if .SkillVersionCompare.ChangedFields}}
            <ul>
                {{range .SkillVersionCompare.ChangedFields}}
                <li>{{.}}</li>
                {{end}}
            </ul>
            {{else}}
            <p class="muted">No field changes detected.</p>
            {{end}}
        </article>
        <article class="matrix-card">
            <h3>Metadata Diff</h3>
            {{if .SkillVersionCompare.MetadataChanges}}
            <table>
                <thead>
                    <tr>
                        <th>Field</th>
                        <th>Before</th>
                        <th>After</th>
                    </tr>
                </thead>
                <tbody>
                    {{range .SkillVersionCompare.MetadataChanges}}
                    <tr>
                        <td>{{.Field}}</td>
                        <td>{{.Before}}</td>
                        <td>{{.After}}</td>
                    </tr>
                    {{end}}
                </tbody>
            </table>
            {{else}}
            <p class="muted">No metadata changes detected.</p>
            {{end}}
            <p><strong>Tags added:</strong> {{if .SkillVersionCompare.TagsAdded}}{{range .SkillVersionCompare.TagsAdded}}#{{.}} {{end}}{{else}}None{{end}}</p>
            <p><strong>Tags removed:</strong> {{if .SkillVersionCompare.TagsRemoved}}{{range .SkillVersionCompare.TagsRemoved}}#{{.}} {{end}}{{else}}None{{end}}</p>
        </article>
        <article class="matrix-card">
            <h3>Content Before</h3>
            <pre>{{.SkillVersionCompare.ContentBefore}}</pre>
            <h3>Content After</h3>
            <pre>{{.SkillVersionCompare.ContentAfter}}</pre>
        </article>
        {{else}}
        <p class="muted">Compare data unavailable.</p>
        {{end}}
    </section>
    {{end}}

